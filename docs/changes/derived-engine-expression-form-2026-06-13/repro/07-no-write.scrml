type MarioState:enum = { Small, Big, Fire }
type Health:enum = { Healthy, AtRisk }
<marioState>: MarioState = MarioState.Small
<engine for=Health derived=match @marioState {
  .Small :> .Healthy
  _      :> .AtRisk
}>
  <Healthy : "OK">
  <AtRisk : "Careful">
</>
${
  function go() {
    @health = .Healthy
  }
}
