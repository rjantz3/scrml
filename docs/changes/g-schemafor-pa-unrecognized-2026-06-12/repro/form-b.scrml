<program>
  ${
    import { schemaFor } from 'scrml:data'
    type Driver:struct = {
      id: integer,
      email: string,
      name: string req length(>=2),
      age: number min(18) max(120)
    }
  }
  <db src="t.db" tables="drivers"/>
  <schema>
    ${ schemaFor(Driver) }
  </>
  <p>schema generated</p>
</program>
