            </thead>
            <tbody class="text-slate-700">
                <tr class="border-b border-slate-200">
                    <td class="py-2 pr-4 font-mono text-xs">&lt;engine&gt; shape</td>
                    <td class="py-2 pr-4">S57 D2.8 (2026-05-04)</td>
