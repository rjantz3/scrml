// machine-basic — canonical modern <engine> form (§51.0.B + §51.0.F).
// State-children carry `rule=` attributes that declare the transition contract.
// The legacy `< engine name=X for=Y>` + arrow-rule body form is retired in
// v0.2.0 (see engine-modern-001-basic.scrml for the reference shape).
//
// The engine auto-declares its reactive variable from `for=` (§51.0.C):
// OrderStatus → @orderStatus.

${
    type OrderStatus:enum = { Pending, Processing, Shipped, Delivered, Cancelled }
}

<engine for=OrderStatus initial=.Pending>
    <Pending    rule=(.Processing | .Cancelled)></>
    <Processing rule=(.Shipped    | .Cancelled)></>
    <Shipped    rule=.Delivered></>
    <Delivered  rule=.Pending></>
    <Cancelled  rule=.Pending></>
</>

<program>
<div>
    <h1>Order Status: ${@orderStatus.variant}</>
    <button onclick=${@orderStatus = .Processing}>Advance</>
    <button onclick=${@orderStatus = .Shipped}>Ship</>
</>
</program>
