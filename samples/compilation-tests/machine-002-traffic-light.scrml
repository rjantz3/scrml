// traffic-light.scrml — §51 modern <engine> gauntlet (state-as-primary).
//
// v0.2.0 canonical: `<engine for=TrafficLight initial=.Red>` with state-children
// carrying `rule=` attributes per §51.0.B + §51.0.F. The pre-v0.2.0
// `< engine name=X for=Y>` arrow-rule body is retired; see engine-modern-001-basic
// for the reference shape and machine-basic.scrml for a simpler analog.
//
// Engine auto-declares `@trafficLight` from `for=TrafficLight` (§51.0.C).
// `class:active=(@x == .Variant)` toggles per-state styling.

${
    type TrafficLight:enum = { Red, Yellow, Green }

    // cycle() advances through Red → Green → Yellow → Red
    // match arms use => (canonical per §51, not :>)
    function cycle() {
        @trafficLight = match @trafficLight {
            .Red    => .Green
            .Green  => .Yellow
            .Yellow => .Red
        }
    }
}

<engine for=TrafficLight initial=.Red>
    <Red    rule=.Green></>
    <Green  rule=.Yellow></>
    <Yellow rule=.Red></>
</>

<div class="traffic-app">

    <h1>Traffic Light Simulator</>

    <div class="light-housing">
        <div
            class="light red-light"
            class:active=(@trafficLight == .Red)
        ></>

        <div
            class="light yellow-light"
            class:active=(@trafficLight == .Yellow)
        ></>

        <div
            class="light green-light"
            class:active=(@trafficLight == .Green)
        ></>
    </>

    <p class="state-label">Current: ${@trafficLight.variant}</>

    <button class="cycle-btn" onclick=cycle()>Advance Signal</>

</>

#{
    .traffic-app {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        padding: 2rem;
        font-family: sans-serif;
        background: #1a1a1a;
        min-height: 100vh;
        color: #eee;
    }

    h1 {
        font-size: 1.4rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        color: #ccc;
    }

    .light-housing {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        background: #2a2a2a;
        border: 3px solid #444;
        border-radius: 16px;
        padding: 1.25rem 1rem;
        width: 96px;
    }

    .light {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        border: 2px solid #333;
        opacity: 0.15;
        transition: opacity 0.2s ease, box-shadow 0.2s ease;
    }

    .red-light {
        background: #e53e3e;
    }

    .red-light.active {
        opacity: 1;
        box-shadow: 0 0 18px 6px rgba(229, 62, 62, 0.7);
    }

    .yellow-light {
        background: #d69e2e;
    }

    .yellow-light.active {
        opacity: 1;
        box-shadow: 0 0 18px 6px rgba(214, 158, 46, 0.7);
    }

    .green-light {
        background: #38a169;
    }

    .green-light.active {
        opacity: 1;
        box-shadow: 0 0 18px 6px rgba(56, 161, 105, 0.7);
    }

    .state-label {
        font-size: 1.1rem;
        font-weight: 500;
        color: #aaa;
        letter-spacing: 0.03em;
    }

    .cycle-btn {
        padding: 0.6rem 2rem;
        font-size: 1rem;
        font-weight: 600;
        background: #3b82f6;
        color: #fff;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        letter-spacing: 0.02em;
        transition: background 0.15s ease;
    }

    .cycle-btn:hover {
        background: #2563eb;
    }
}
