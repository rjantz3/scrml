// Phase 10: basic channel declaration (§38)
// v0.3: channel sits INSIDE program element (SPEC §38.1 — direction
// reversed from pre-v0.3 which fired E-CHANNEL-INSIDE-PROGRAM; now
// E-CHANNEL-OUTSIDE-PROGRAM fires on file-top channels). This fixture
// is already in v0.3-canonical placement; the retired E-CHANNEL-INSIDE-
// PROGRAM trigger no longer fires here. Should compile clean (minus
// any unrelated source issues in this fixture's expression body).

<program>
${
  <messages> = []
  <status> = "disconnected"
}

<div>
  <channel name="updates"
           topic="main"
           onclient:open=onOpen()
           onclient:close=onClose()
           onserver:message=handleMsg(msg)>
  </>

  <p>Status: ${@status}</>
  <ul>
    <each in=@messages>
      <li>${@.}</>
    </each>
  </ul>
</div>
</program>
