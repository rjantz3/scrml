// Phase 10: multiple channels in one app (§38)
// v0.3: channels sit INSIDE program element (SPEC §38.1 — direction
// reversed from pre-v0.3). Already in v0.3-canonical placement.
// Should compile clean — each channel gets its own route.

<program>
${
  <chatMessages> = []
  <notifications> = []
}

<div>
  <channel name="chat"
           topic="general"
           onserver:message=handleChat(msg)>
  </>

  <channel name="alerts"
           topic="system"
           onserver:message=handleAlert(msg)>
  </>

  <div>
    <h2>Chat</>
    <ul>
      <each in=@chatMessages>
        <li>${@.}</>
      </each>
    </ul>
  </div>

  <div>
    <h2>Alerts</>
    <ul>
      <each in=@notifications>
        <li>${@.}</>
      </each>
    </ul>
  </div>
</div>
</program>
