// when-002-message-handler.scrml
// when message {} — message handler inside a nested <program> worker (§43.5.2, §46).
// Tests: nested program + message passing + when message from.

<program>

// Worker: receives a number, doubles it, sends back.
<program name="doubler">
    ${
        when message(data) {
            send({ result: data.value * 2 })
        }
    }
</>

${
    <value>  = 21
    <result> = not

    function runDoubler() {
        <#doubler>.send({ value: @value })
    }

    when message from <#doubler> (data) {
        @result = data.result
    }
}

<div>
    <input type="number" bind:value=@value>
    <button onclick=runDoubler()>Double it</>
    <p if=(@result is not not)>Result: ${@result}</>
</>

</program>
