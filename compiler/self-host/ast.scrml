<program>
${
    // ---------------------------------------------------------------------------
    // scrml:compiler/ast-builder — AST Builder (Stage 3b / TAB)
    //
    // Self-hosted port of compiler/src/ast-builder.js.
    // Receives the Block tree from the Block Splitter and the token streams
    // produced by the Tokenizer, then constructs a typed FileAST.
    //
    // Exports: TABError, buildAST, runTAB, parseLogicBody
    // ---------------------------------------------------------------------------

    // Meta block — anchors the library-mode codegen gap detection so that
    // helper declarations before the first export are captured in the output.
    ^{}

    // ---------------------------------------------------------------------------
    // Imports — tokenizer functions
    // ---------------------------------------------------------------------------

    ^{
        const { tokenizeAttributes, tokenizeLogic, tokenizeSQL, tokenizeCSS, tokenizeError, tokenizePassthrough } = await import("./tokenizer.js")
    }

    // ---------------------------------------------------------------------------
    // Expression parser import — for ExprNode parallel fields (Phase 1/2)
    // ---------------------------------------------------------------------------

    // In production (compiled scrml), parseExprToNode is available via ^{} import.
    // In test context (Blob URL), ^{} blocks are stripped — this fallback handles it.
    let parseExprToNode = undefined
    try {
        const _ep = await import(new URL("../src/expression-parser.ts", import.meta.url).href)
        parseExprToNode = _ep.parseExprToNode
    } catch {
        try {
            const _ep = await import(process.cwd() + "/compiler/src/expression-parser.ts")
            parseExprToNode = _ep.parseExprToNode
        } catch {
            // expression parser not available — ExprNode fields will be undefined
        }
    }

    // ---------------------------------------------------------------------------
    // Error type
    // ---------------------------------------------------------------------------

    export class TABError extends Error {
        constructor(code, message, span) {
            super(message + " (line " + span.line + ", col " + span.col + ")")
            this.name = "TABError"
            this.code = code
            this.tabSpan = span
        }
    }

    // ---------------------------------------------------------------------------
    // Span helpers
    // ---------------------------------------------------------------------------

    fn fullSpan(bsSpan, filePath) {
        return {
            file: filePath,
            start: bsSpan.start,
            end: bsSpan.end,
            line: bsSpan.line,
            col: bsSpan.col,
        }
    }

    fn tokenSpan(tok, filePath) {
        return {
            file: filePath,
            start: tok.span.start,
            end: tok.span.end,
            line: tok.span.line,
            col: tok.span.col,
        }
    }

    // ---------------------------------------------------------------------------
    // Known boolean HTML attributes (E-ATTR-002 set)
    // ---------------------------------------------------------------------------

    const BOOLEAN_ATTRS = new Set([
        "disabled",
        "checked",
        "readonly",
        "required",
        "selected",
        "multiple",
        "open",
        "hidden",
    ])

    // ---------------------------------------------------------------------------
    // Supported bind: directive names
    // ---------------------------------------------------------------------------

    const BIND_DIRECTIVES = new Set([
        "bind:value",
        "bind:checked",
        "bind:selected",
        "bind:group",
        "bind:files",
    ])

    // ---------------------------------------------------------------------------
    // Block context label
    // ---------------------------------------------------------------------------

    fn contextLabel(ctx) {
        if (ctx == "meta") return "`^" + String.fromCharCode(123) + " " + String.fromCharCode(125) + "` meta"
        if (ctx == "sql") return "`?" + String.fromCharCode(123) + " " + String.fromCharCode(125) + "` SQL"
        if (ctx == "css") return "`#" + String.fromCharCode(123) + " " + String.fromCharCode(125) + "` CSS"
        if (ctx == "error") return "`!" + String.fromCharCode(123) + " " + String.fromCharCode(125) + "` error"
        if (ctx == "state") return "state"
        if (ctx == "markup") return "markup"
        return "`" + ctx + "`"
    }

    // ---------------------------------------------------------------------------
    // Attribute parsing helpers
    // ---------------------------------------------------------------------------

    function parseAttributes(tokens, filePath, errors, isComponent) {
        if (isComponent == null) isComponent = false
        const attrs = []
        let i = 0

        while (i < tokens.length) {
            const tok = tokens[i]

            if (tok.kind == "ATTR_NAME") {
                const nameSpan = tokenSpan(tok, filePath)
                const name = tok.text
                i++

                // Check for ATTR_EQ
                if (i < tokens.length && tokens[i].kind == "ATTR_EQ") {
                    i++ // consume =

                    if (i < tokens.length) {
                        const valTok = tokens[i]
                        i++

                        let value
                        const valSpan = tokenSpan(valTok, filePath)
                        if (valTok.kind == "ATTR_STRING") {
                            value = { kind: "string-literal", value: valTok.text, span: valSpan }
                            // E-ATTR-002: boolean attribute with a quoted string value
                            if (BOOLEAN_ATTRS.has(name)) {
                                errors.push(new TABError(
                                    "E-ATTR-002",
                                    "E-ATTR-002: Attribute `" + name + "` is a boolean attribute but was given a quoted string value `\"" + valTok.text + "\"`. " +
                                    "Use an unquoted boolean expression instead — for example `" + name + "=myBoolVar` or omit the value entirely for `" + name + "` (presence = true).",
                                    valSpan,
                                ))
                            }
                        } else if (valTok.kind == "ATTR_CALL") {
                            let parsed
                            try { parsed = JSON.parse(valTok.text) } catch (e) { parsed = { name: valTok.text, args: "" } }
                            const rawArgs = parsed.args || ""
                            const argList = rawArgs.trim().length == 0
                                ? []
                                : splitArgs(rawArgs)
                            value = { kind: "call-ref", name: parsed.name, args: argList, span: valSpan }
                        } else if (valTok.kind == "ATTR_IDENT") {
                            value = { kind: "variable-ref", name: valTok.text, span: valSpan }
                        } else if (valTok.kind == "ATTR_BLOCK") {
                            const propsDecl = parsePropsBlock(valTok.text, valSpan, errors)
                            value = { kind: "props-block", propsDecl, span: valSpan }
                        } else if (valTok.kind == "ATTR_EXPR") {
                            const raw = valTok.text
                            const refs = []
                            const refRe = /@([A-Za-z_$][A-Za-z0-9_$]*)/g
                            let m
                            while ((m = refRe.exec(raw)) != null) {
                                if (!refs.includes(m[1])) refs.push(m[1])
                            }
                            value = { kind: "expr", raw, refs, span: valSpan }
                        } else {
                            errors.push(new TABError(
                                "E-ATTR-001",
                                "E-ATTR-001: The value `" + valTok.text + "` is not valid for attribute `" + name + "`. " +
                                "Attribute values must be a quoted string literal, an unquoted identifier, or a call expression — " +
                                "for example `" + name + '="value"`, `' + name + "=myVar`, or `" + name + "=fn()`.",
                                valSpan,
                            ))
                            value = { kind: "absent" }
                        }

                        // Span covers name through end of value
                        const attrSpan = {
                            file: filePath,
                            start: nameSpan.start,
                            end: tokenSpan(valTok, filePath).end,
                            line: nameSpan.line,
                            col: nameSpan.col,
                        }

                        // bind: directive validation
                        if (name.startsWith("bind:")) {
                            if (!BIND_DIRECTIVES.has(name) && !isComponent) {
                                errors.push(new TABError(
                                    "E-ATTR-011",
                                    "E-ATTR-011: `" + name + "` is not a supported bind directive. " +
                                    "Supported bind directives are: `bind:value`, `bind:checked`, `bind:selected`, `bind:group`. " +
                                    "If you intended a regular attribute, remove the `bind:` prefix.",
                                    attrSpan,
                                ))
                            }
                            if (value.kind == "variable-ref") {
                                if (!value.name.startsWith("@") && !value.name.includes(".")) {
                                    errors.push(new TABError(
                                        "E-ATTR-010",
                                        "E-ATTR-010: `" + name + "` requires a reactive `@` variable or state field path. " +
                                        "`" + value.name + "` is not reactive. " +
                                        "Use `@" + value.name + "` or a state field path like `stateObj.field`.",
                                        attrSpan,
                                    ))
                                }
                            } else if (value.kind == "string-literal") {
                                errors.push(new TABError(
                                    "E-ATTR-010",
                                    "E-ATTR-010: `" + name + "` requires a reactive `@` variable. " +
                                    'Got a string literal `"' + value.value + '"` instead. ' +
                                    "Use an `@`-prefixed reactive variable, e.g. `" + name + "=@myVar`.",
                                    attrSpan,
                                ))
                            }
                        }

                        // class: directive validation — E-ATTR-013
                        if (name.startsWith("class:")) {
                            if (value.kind == "variable-ref") {
                                const _isReactive = value.name.startsWith("@")
                                const _isDotPath = !_isReactive && value.name.includes(".")
                                if (!_isReactive && !_isDotPath) {
                                    errors.push(new TABError(
                                        "E-ATTR-013",
                                        "E-ATTR-013: `" + name + "` requires a boolean expression. " +
                                        "`" + value.name + "` is a bare identifier — did you mean `@" + value.name + "`? " +
                                        "Valid forms: `" + name + "=@myVar`, `" + name + "=obj.prop`, `" + name + "=(expr)`, `" + name + "=fn()`.",
                                        attrSpan,
                                    ))
                                }
                            } else if (value.kind == "string-literal") {
                                errors.push(new TABError(
                                    "E-ATTR-013",
                                    "E-ATTR-013: `" + name + "` requires a boolean expression, not a string literal. " +
                                    'Got `"' + value.value + '"`. ' +
                                    "Valid forms: `" + name + "=@myVar`, `" + name + "=obj.prop`, `" + name + "=(expr)`, `" + name + "=fn()`.",
                                    attrSpan,
                                ))
                            } else if (value.kind == "absent") {
                                errors.push(new TABError(
                                    "E-ATTR-013",
                                    "E-ATTR-013: `" + name + "` requires a boolean expression. " +
                                    "No value was provided. Valid forms: `" + name + "=@myVar`, `" + name + "=obj.prop`, `" + name + "=(expr)`, `" + name + "=fn()`.",
                                    attrSpan,
                                ))
                            }
                        }

                        attrs.push({ name, value, span: attrSpan })
                    }
                } else {
                    // Boolean attribute — no value
                    if (name.startsWith("class:")) {
                        errors.push(new TABError(
                            "E-ATTR-013",
                            "E-ATTR-013: `" + name + "` requires a reactive `@` variable. " +
                            "No value was provided. Use `" + name + "=@myVar`.",
                            nameSpan,
                        ))
                    }
                    attrs.push({ name, value: { kind: "absent" }, span: nameSpan })
                }
                continue
            }

            // Skip TAG_OPEN, TAG_CLOSE_GT, TAG_SELF_CLOSE, EOF
            i++
        }

        return attrs
    }

    // ---------------------------------------------------------------------------
    // tagFunctionsWithStateType
    // ---------------------------------------------------------------------------

    function tagFunctionsWithStateType(nodes, stateTypeName) {
        for (const node of nodes) {
            if (!node || typeof node != "object") continue
            if (node.kind == "function-decl") {
                node.stateTypeScope = stateTypeName
            }
            if (node.kind == "logic" && Array.isArray(node.body)) {
                for (const stmt of node.body) {
                    if (stmt && (stmt.kind == "function-decl")) {
                        stmt.stateTypeScope = stateTypeName
                    }
                }
            }
            if (Array.isArray(node.children)) {
                tagFunctionsWithStateType(node.children, stateTypeName)
            }
        }
    }

    // ---------------------------------------------------------------------------
    // parseTypedAttributes
    // ---------------------------------------------------------------------------

    function parseTypedAttributes(tokens, filePath, errors) {
        const attrs = []
        const typedAttrs = []
        let hasTypedDecls = false
        let i = 0

        while (i < tokens.length) {
            const tok = tokens[i]

            if (tok.kind == "ATTR_TYPED_DECL") {
                hasTypedDecls = true
                let parsed
                try { parsed = JSON.parse(tok.text) } catch (e) { parsed = { name: "?", typeExpr: "" } }

                const name = parsed.name
                const rawTypeExpr = parsed.typeExpr
                const span = tokenSpan(tok, filePath)

                let typeExpr = rawTypeExpr.trim()
                let defaultValue = null
                const eqIdx = typeExpr.indexOf("=")
                if (eqIdx != -1) {
                    defaultValue = typeExpr.slice(eqIdx + 1).trim()
                    typeExpr = typeExpr.slice(0, eqIdx).trim()
                }

                let optional = false
                if (typeExpr.endsWith("?")) {
                    optional = true
                    typeExpr = typeExpr.slice(0, -1).trim()
                }

                if (defaultValue != null) {
                    optional = true
                }

                typedAttrs.push({ name, typeExpr, optional, defaultValue, span })
                i++
                continue
            }

            if (tok.kind == "ATTR_NAME") {
                const nameSpan = tokenSpan(tok, filePath)
                const name = tok.text
                i++

                if (i < tokens.length && tokens[i].kind == "ATTR_EQ") {
                    i++ // consume =

                    if (i < tokens.length) {
                        const valTok = tokens[i]
                        i++

                        let value
                        const valSpan = tokenSpan(valTok, filePath)
                        if (valTok.kind == "ATTR_STRING") {
                            value = { kind: "string-literal", value: valTok.text, span: valSpan }
                        } else if (valTok.kind == "ATTR_IDENT") {
                            value = { kind: "variable-ref", name: valTok.text, span: valSpan }
                        } else {
                            value = { kind: "absent" }
                        }

                        const attrSpan = {
                            file: filePath,
                            start: nameSpan.start,
                            end: tokenSpan(valTok, filePath).end,
                            line: nameSpan.line,
                            col: nameSpan.col,
                        }
                        attrs.push({ name, value, span: attrSpan })
                    }
                } else {
                    attrs.push({ name, value: { kind: "absent" }, span: nameSpan })
                }
                continue
            }

            i++
        }

        return { attrs, typedAttrs, hasTypedDecls }
    }

    // ---------------------------------------------------------------------------
    // splitArgs
    // ---------------------------------------------------------------------------

    fn splitArgs(raw) {
        const OPEN_BRACE = String.fromCharCode(123)
        const CLOSE_BRACE = String.fromCharCode(125)
        const parts = []
        let depth = 0
        let cur = ""
        for (const ch of raw) {
            if (ch == "(" || ch == "[" || ch == OPEN_BRACE) { depth++; cur += ch }
            else if (ch == ")" || ch == "]" || ch == CLOSE_BRACE) { depth--; cur += ch }
            else if (ch == "," && depth == 0) {
                parts.push(cur.trim())
                cur = ""
            } else {
                cur += ch
            }
        }
        if (cur.trim().length > 0) parts.push(cur.trim())
        return parts
    }

    // ---------------------------------------------------------------------------
    // splitAtTopLevelCommas
    // ---------------------------------------------------------------------------

    fn splitAtTopLevelCommas(raw) {
        const OPEN_BRACE = String.fromCharCode(123)
        const CLOSE_BRACE = String.fromCharCode(125)
        const parts = []
        let depth = 0
        let current = ""
        for (const ch of raw) {
            if (ch == OPEN_BRACE || ch == "(" || ch == "[") { depth++; current += ch }
            else if (ch == CLOSE_BRACE || ch == ")" || ch == "]") { depth--; current += ch }
            else if (ch == "," && depth == 0) {
                parts.push(current)
                current = ""
            } else {
                current += ch
            }
        }
        if (current.trim()) parts.push(current)
        return parts
    }

    // ---------------------------------------------------------------------------
    // parsePropsBlock
    // ---------------------------------------------------------------------------

    fn parsePropsBlock(raw, span, errors) {
        const props = []
        const parts = splitAtTopLevelCommas(raw)

        for (const part of parts) {
            const trimmed = part.trim()
            if (!trimmed) continue

            let bindable = false
            let propText = trimmed
            if (propText.startsWith("bind ")) {
                bindable = true
                propText = propText.slice(5).trim()
            }

            const match = propText.match(/^([A-Za-z_][A-Za-z0-9_]*)(\?)?\s*:\s*(.+)$/)
            if (!match) {
                errors.push(new TABError(
                    "E-COMPONENT-019",
                    "E-COMPONENT-019: Invalid prop declaration `" + trimmed + "` in props block. " +
                    "Expected format: `name: type`, `name?: type`, `name: type = default`, " +
                    "`bind name: type` (bindable prop), or `name: fn-signature` (function prop).",
                    span,
                ))
                continue
            }

            const name = match[1]
            const optional = match[2] == "?"
            let typeAndDefault = match[3].trim()

            let defaultValue = null
            const eqMatch = typeAndDefault.match(/^(.+?)\s*=(?!=|>)\s*(.+)$/)
            if (eqMatch) {
                typeAndDefault = eqMatch[1].trim()
                defaultValue = eqMatch[2].trim()
            }

            const isFunctionProp = typeAndDefault.includes("=>") || typeAndDefault.trim().startsWith("(")

            props.push({
                name,
                type: typeAndDefault,
                optional: optional || defaultValue != null,
                default: defaultValue,
                bindable,
                isFunctionProp,
            })
        }

        return props
    }

    // ---------------------------------------------------------------------------
    // Logic block parser
    // ---------------------------------------------------------------------------

    export function parseLogicBody(tokens, filePath, childBlocks, parentBlock, counter, errors, blockContext) {
        const nodes = []
        let i = 0

        function peek(n) {
            if (n == null) n = 0
            return i + n < tokens.length ? tokens[i + n] : { kind: "EOF", text: "", span: { start: 0, end: 0, line: 1, col: 1 } }
        }

        function consume() {
            return i < tokens.length ? tokens[i++] : peek()
        }

        function spanOf(startTok, endTok) {
            return {
                file: filePath,
                start: startTok.span.start,
                end: endTok.span.end,
                line: startTok.span.line,
                col: startTok.span.col,
            }
        }

        // joinWithNewlines: preserve source line breaks between tokens
        function joinWithNewlines(parts, partLines) {
            if (parts.length == 0) return ""
            let result = parts[0]
            for (let i = 1; i < parts.length; i++) {
                const sep = (partLines[i] > partLines[i - 1]) ? "\n" : " "
                result += sep + parts[i]
            }
            return result
        }


        // safeParseExprToNode — Phase 1/2 ExprNode parallel fields
        function safeParseExprToNode(expr, startOffset) {
            if (!parseExprToNode) return undefined
            if (!expr || typeof expr !== "string" || !expr.trim()) return undefined
            try {
                return parseExprToNode(expr, filePath || "", startOffset || 0)
            } catch (_e) {
                return undefined
            }
        }

        // collectExpr
        function collectExpr(stopAt) {
            if (stopAt == null) stopAt = null
            const OPEN_BRACE = String.fromCharCode(123)
            const CLOSE_BRACE = String.fromCharCode(125)
            const parts = []
            const partLines = []
            const startTok = peek()
            let lastTok = startTok
            let depth = 0
            let angleDepth = 0

            const STMT_KEYWORDS = new Set(["lift", "function", "fn", "const", "let", "import", "export", "use", "type", "server", "for", "while", "if", "return", "match", "switch", "try", "fail", "transaction", "throw"])
            const DECL_KEYWORDS = new Set(["const", "let", "type", "function", "fn"])

            // Build the triple-equals string via concatenation to avoid scrml rejection
            const TRIPLE_EQ = "==" + "="
            const BANG_DOUBLE_EQ = "!" + "==" + ""

            while (true) {
                const tok = peek()
                if (tok.kind == "EOF") break
                if (tok.kind == "COMMENT") { consume(); continue }
                if (stopAt && tok.text == stopAt && depth == 0) break
                if (tok.kind == "BLOCK_REF" && depth == 0 && parts.length > 0) break
                if (depth == 0) {
                    if (tok.kind == "PUNCT" && tok.text == ";") {
                        lastTok = consume()
                        break
                    }
                    if (tok.kind == "PUNCT" && tok.text == CLOSE_BRACE) break
                    if (parts.length > 0 && tok.kind == "KEYWORD" && STMT_KEYWORDS.has(tok.text)) break
                    if (parts.length > 0 && angleDepth == 0) {
                        const lastPart = parts[parts.length - 1]
                        if (!DECL_KEYWORDS.has(lastPart)) {
                            const next1 = peek(1)
                            const isAssign = next1 && next1.kind == "PUNCT" && next1.text == "=" && peek(2) && peek(2).text != "="
                            if (isAssign) {
                                if (tok.kind == "AT_IDENT") break
                                if (tok.kind == "IDENT" && lastPart != ".") break
                            }
                        }
                    }
                    if (
                        parts.length > 0 &&
                        angleDepth == 0 &&
                        // (Slice 3) removed redundant identity check — parts.length > 0 already
                        // means "consumed at least one token". The identity check was an
                        // off-by-one (peek/consume return the same object).
                        tok.span.line > lastTok.span.line
                    ) {
                        const lastKind = lastTok.kind
                        const lastText = lastTok.text
                        const lastEndsValue = (
                            lastKind == "IDENT" ||
                            lastKind == "NUMBER" ||
                            lastKind == "STRING" ||
                            (lastKind == "PUNCT" && (lastText == ")" || lastText == "]"))
                        )
                        const tokStartsStmt = (
                            tok.kind == "IDENT" ||
                            (tok.kind == "KEYWORD" && !STMT_KEYWORDS.has(tok.text))
                        )
                        if (lastEndsValue && tokStartsStmt) break
                    }
                }
                if (tok.kind == "PUNCT" && (tok.text == OPEN_BRACE || tok.text == "(" || tok.text == "[")) depth++
                if (tok.kind == "PUNCT" && (tok.text == CLOSE_BRACE || tok.text == ")" || tok.text == "]")) {
                    if (depth == 0) break
                    depth--
                }
                if (tok.kind == "PUNCT" && tok.text == "<" && depth == 0) {
                    const afterLt = peek(1)
                    if (afterLt && (afterLt.kind == "IDENT" || afterLt.kind == "KEYWORD")) {
                        angleDepth++
                    }
                }
                if (angleDepth > 0 && tok.kind == "PUNCT" && tok.text == ">" && depth == 0) {
                    angleDepth--
                }
                // E-EQ-004
                if (tok.kind == "OPERATOR" && (tok.text == TRIPLE_EQ || tok.text == BANG_DOUBLE_EQ)) {
                    const eqSpan = tokenSpan(tok, filePath)
                    const replacement = tok.text == TRIPLE_EQ ? "==" : "!="
                    errors.push(new TABError(
                        "E-EQ-004",
                        "E-EQ-004: `" + tok.text + "` is not a valid scrml operator. Use `" + replacement + "` instead — scrml equality is always strict.",
                        eqSpan,
                    ))
                    lastTok = consume()
                    parts.push(replacement)
                    partLines.push(lastTok.span?.line ?? 0)
                    continue
                }
                lastTok = consume()
                if (lastTok.kind == "STRING") {
                    parts.push('"' + lastTok.text.replace(/\\/g, "\\\\").replace(/"/g, '\\"') + '"')
                } else {
                    parts.push(lastTok.text)
                }
                partLines.push(lastTok.span?.line ?? 0)
            }

            return {
                expr: joinWithNewlines(parts, partLines),
                span: parts.length > 0 ? spanOf(startTok, lastTok) : spanOf(startTok, startTok),
            }
        }

        // collectBracedBody
        function collectBracedBody() {
            const OPEN_BRACE = String.fromCharCode(123)
            const CLOSE_BRACE = String.fromCharCode(125)
            const startTok = peek()
            let depth = 1
            const parts = []
            const partLines = []
            let lastTok = startTok

            while (depth > 0) {
                const tok = peek()
                if (tok.kind == "EOF") break
                if (tok.kind == "PUNCT" && tok.text == OPEN_BRACE) depth++
                if (tok.kind == "PUNCT" && tok.text == CLOSE_BRACE) {
                    depth--
                    if (depth == 0) { lastTok = consume(); break }
                }
                lastTok = consume()
                parts.push(lastTok.text)
                partLines.push(lastTok.span?.line ?? 0)
            }

            return {
                body: joinWithNewlines(parts, partLines),
                span: parts.length > 0 ? spanOf(startTok, lastTok) : spanOf(startTok, startTok),
            }
        }

        // collectLiftExpr
        function collectLiftExpr() {
            const OPEN_BRACE = String.fromCharCode(123)
            const CLOSE_BRACE = String.fromCharCode(125)
            const parts = []
            const partLines = []
            const startTok = peek()
            let lastTok = startTok
            let depth = 0

            const STMT_KEYWORDS = new Set(["lift", "function", "fn", "const", "let", "import", "export", "use", "type", "server", "for", "while", "if", "return", "match", "switch", "try", "fail", "transaction", "throw"])

            while (true) {
                const tok = peek()
                if (tok.kind == "EOF") break
                if (tok.kind == "BLOCK_REF" && depth == 0 && parts.length > 0) break
                if (depth == 0) {
                    if (tok.kind == "PUNCT" && tok.text == ";") {
                        lastTok = consume()
                        break
                    }
                    if (tok.kind == "PUNCT" && tok.text == CLOSE_BRACE) break
                    if (parts.length > 0 && tok.kind == "KEYWORD" && STMT_KEYWORDS.has(tok.text)) break
                }
                if (tok.kind == "PUNCT" && (tok.text == OPEN_BRACE || tok.text == "(" || tok.text == "[")) depth++
                if (tok.kind == "PUNCT" && (tok.text == CLOSE_BRACE || tok.text == ")" || tok.text == "]")) {
                    if (depth == 0) break
                    depth--
                }
                lastTok = consume()
                if (lastTok.kind == "STRING") {
                    parts.push('"' + lastTok.text.replace(/\\/g, "\\\\").replace(/"/g, '\\"') + '"')
                } else {
                    parts.push(lastTok.text)
                }
                partLines.push(lastTok.span?.line ?? 0)
            }

            return {
                expr: joinWithNewlines(parts, partLines),
                span: parts.length > 0 ? spanOf(startTok, lastTok) : spanOf(startTok, startTok),
            }
        }

        // parseRecursiveBody
        function parseRecursiveBody() {
            const CLOSE_BRACE = String.fromCharCode(125)
            const stmts = []
            while (true) {
                const tok = peek()
                if (tok.kind == "EOF") break
                if (tok.kind == "PUNCT" && tok.text == CLOSE_BRACE) {
                    consume()
                    break
                }
                if (tok.kind == "PUNCT" && tok.text == ";") { consume(); continue }
                if (tok.kind == "COMMENT") { consume(); continue }
                if (tok.text.trim() == "" && tok.kind != "EOF") { consume(); continue }

                const node = parseOneStatement()
                if (node) {
                    const nextTok = peek()
                    if (nextTok.kind == "BLOCK_REF" && nextTok.block && nextTok.block.type == "error-effect") {
                        consume()
                        const errBlock = buildBlock(nextTok.block, filePath, parentBlock.type, counter, errors)
                        stmts.push({
                            id: ++counter.next,
                            kind: "guarded-expr",
                            guardedNode: node,
                            arms: errBlock ? errBlock.arms : [],
                            span: { ...node.span, end: nextTok.block.span.end },
                        })
                    } else {
                        stmts.push(node)
                    }
                }
            }
            return stmts
        }

        // parseOneStatement
        function parseOneStatement() {
            const OPEN_BRACE = String.fromCharCode(123)
            const CLOSE_BRACE = String.fromCharCode(125)
            const tok = peek()

            // BLOCK_REF
            if (tok.kind == "BLOCK_REF") {
                consume()
                const child = tok.block
                if (child) {
                    const childNode = buildBlock(child, filePath, parentBlock.type, counter, errors)
                    if (childNode) {
                        childNode.span = fullSpan(child.span, filePath)
                        if (childNode.kind == "sql" && childNode.chainedCalls) {
                            while (peek().kind == "PUNCT" && peek().text == ".") {
                                consume()
                                if (peek().kind == "IDENT") {
                                    const methodTok = consume()
                                    let args = ""
                                    if (peek().kind == "PUNCT" && peek().text == "(") {
                                        consume()
                                        while (peek().kind != "EOF" && !(peek().kind == "PUNCT" && peek().text == ")")) {
                                            args += consume().text
                                        }
                                        if (peek().kind == "PUNCT" && peek().text == ")") consume()
                                    }
                                    childNode.chainedCalls.push({ method: methodTok.text, args })
                                }
                            }
                        }
                        return childNode
                    }
                }
                return null
            }

            // LET
            if (tok.kind == "KEYWORD" && tok.text == "let") {
                const startTok = consume()
                let name = ""
                if (peek().kind == "IDENT") name = consume().text
                else if (peek().kind == "KEYWORD") name = consume().text
                if (peek().text == "=" && peek(1) && peek(1).text != "=") {
                    consume()
                    const result = collectExpr()
                    return { id: ++counter.next, kind: "let-decl", name, init: result.expr, initExpr: safeParseExprToNode(result.expr, spanOf(startTok, peek())?.start ?? 0), span: spanOf(startTok, peek()) }
                } else {
                    const result = collectExpr()
                    return { id: ++counter.next, kind: "let-decl", name, init: result.expr, initExpr: safeParseExprToNode(result.expr, spanOf(startTok, peek())?.start ?? 0), span: spanOf(startTok, peek()) }
                }
            }

            // CONST
            if (tok.kind == "KEYWORD" && tok.text == "const") {
                const startTok = consume()
                if (peek().kind == "AT_IDENT") {
                    const atTok = consume()
                    const derivedName = atTok.text.slice(1)
                    if (peek().text == "=" && peek(1) && peek(1).text != "=") {
                        consume()
                        const result = collectExpr()
                        return { id: ++counter.next, kind: "reactive-derived-decl", name: derivedName, init: result.expr, initExpr: safeParseExprToNode(result.expr, spanOf(startTok, peek())?.start ?? 0), span: spanOf(startTok, peek()) }
                    } else {
                        return { id: ++counter.next, kind: "reactive-derived-decl", name: derivedName, init: "", span: spanOf(startTok, peek()) }
                    }
                }
                let name = ""
                if (peek().kind == "IDENT" || peek().kind == "KEYWORD") name = consume().text
                if (peek().text == "=" && peek(1) && peek(1).text != "=") {
                    consume()
                    const result = collectExpr()
                    return { id: ++counter.next, kind: "const-decl", name, init: result.expr, initExpr: safeParseExprToNode(result.expr, spanOf(startTok, peek())?.start ?? 0), span: spanOf(startTok, peek()) }
                } else {
                    return { id: ++counter.next, kind: "const-decl", name, init: "", span: tokenSpan(startTok, filePath) }
                }
            }

            // @debounced(N)
            if (tok.kind == "AT_IDENT" && tok.text == "@debounced") {
                const startTok = consume()
                let delay = 300
                if (peek().text == "(") {
                    consume()
                    const delayParts = []
                    while (peek().text != ")" && peek().kind != "EOF") {
                        delayParts.push(consume().text)
                    }
                    if (peek().text == ")") consume()
                    delay = parseInt(delayParts.join("").trim(), 10) || 300
                }
                let name = ""
                if (peek().kind == "IDENT" || peek().kind == "KEYWORD") name = consume().text
                if (peek().text == "=" && peek(1) && peek(1).text != "=") {
                    consume()
                    const result = collectExpr()
                    return { id: ++counter.next, kind: "reactive-debounced-decl", name, init: result.expr, initExpr: safeParseExprToNode(result.expr, spanOf(startTok, peek())?.start ?? 0), delay, span: spanOf(startTok, peek()) }
                }
                const result = collectExpr()
                return { id: ++counter.next, kind: "bare-expr", expr: startTok.text + " " + name + (result.expr ? " " + result.expr : ""), span: spanOf(startTok, peek()) }
            }

            // @shared
            if (tok.kind == "AT_IDENT" && tok.text == "@shared") {
                const startTok = consume()
                if ((peek().kind == "IDENT" || peek().kind == "KEYWORD") && peek(1) && peek(1).text == "=" && peek(2) && peek(2).text != "=") {
                    const nameTok = consume()
                    consume()
                    const result = collectExpr()
                    return { id: ++counter.next, kind: "state-decl", name: nameTok.text, init: result.expr, initExpr: safeParseExprToNode(result.expr, spanOf(startTok, peek())?.start ?? 0), isShared: true, shape: "plain", structuralForm: false, isConst: false, span: spanOf(startTok, peek()) }
                }
                const result = collectExpr()
                return { id: ++counter.next, kind: "bare-expr", expr: startTok.text + (result.expr ? " " + result.expr : ""), span: spanOf(startTok, peek()) }
            }

            // REACTIVE DECL / NESTED ASSIGN / ARRAY MUTATION: @name...
            if (tok.kind == "AT_IDENT") {
                const startTok = consume()
                const name = tok.text.slice(1)

                if (peek().text == ".") {
                    const pathSegments = []
                    const tempTokens = []

                    while (peek().text == ".") {
                        const dotTok = consume()
                        tempTokens.push(dotTok)
                        if (peek().kind == "IDENT" || peek().kind == "KEYWORD") {
                            const segTok = consume()
                            tempTokens.push(segTok)
                            pathSegments.push(segTok.text)
                        } else {
                            break
                        }
                    }

                    const ARRAY_MUTATIONS = ["push", "pop", "shift", "unshift", "splice", "sort", "reverse", "fill"]
                    const lastSeg = pathSegments[pathSegments.length - 1]
                    if (pathSegments.length == 1 && ARRAY_MUTATIONS.includes(lastSeg) && peek().text == "(") {
                        consume()
                        const argParts = []
                        let parenDepth = 1
                        while (parenDepth > 0 && peek().kind != "EOF") {
                            const t = consume()
                            if (t.text == "(") parenDepth++
                            if (t.text == ")") { parenDepth--; if (parenDepth == 0) break }
                            argParts.push(t.text)
                        }
                        return {
                            id: ++counter.next,
                            kind: "reactive-array-mutation",
                            target: name,
                            method: lastSeg,
                            args: argParts.join(" ").trim(),
                            span: spanOf(startTok, peek()),
                        }
                    }

                    if (peek().text == "=" && peek(1) && peek(1).text != "=") {
                        consume()
                        const result = collectExpr()
                        return {
                            id: ++counter.next,
                            kind: "reactive-nested-assign",
                            target: name,
                            path: pathSegments,
                            value: result.expr,
                            valueExpr: safeParseExprToNode(result.expr, 0),
                            span: spanOf(startTok, peek()),
                        }
                    }

                    const pathStr = "." + pathSegments.join(".")
                    const result = collectExpr()
                    return { id: ++counter.next, kind: "bare-expr", expr: startTok.text + pathStr + (result.expr ? " " + result.expr : ""), span: spanOf(startTok, peek()) }
                }

                // Simple reactive decl
                if (peek().text == "=" && peek(1) && peek(1).text != "=") {
                    consume()
                    const result = collectExpr()
                    return { id: ++counter.next, kind: "state-decl", name, init: result.expr, initExpr: safeParseExprToNode(result.expr, spanOf(startTok, peek())?.start ?? 0), shape: "plain", structuralForm: false, isConst: false, span: spanOf(startTok, peek()) }
                }

                // @set
                if (name == "set" && peek().text == "(") {
                    consume()
                    const argParts = []
                    let parenDepth = 1
                    while (parenDepth > 0 && peek().kind != "EOF") {
                        const t = consume()
                        if (t.text == "(") parenDepth++
                        if (t.text == ")") { parenDepth--; if (parenDepth == 0) break }
                        argParts.push(t.text)
                    }
                    const argsStr = argParts.join(" ").trim()
                    return {
                        id: ++counter.next,
                        kind: "reactive-explicit-set",
                        args: argsStr,
                        span: spanOf(startTok, peek()),
                    }
                }

                const result = collectExpr()
                return { id: ++counter.next, kind: "bare-expr", expr: startTok.text + (result.expr ? " " + result.expr : ""), span: spanOf(startTok, peek()) }
            }

            // LIFT
            if (tok.kind == "KEYWORD" && tok.text == "lift") {
                const startTok = consume()
                if (peek().kind == "BLOCK_REF") {
                    const refTok = consume()
                    const child = refTok.block
                    if (child) {
                        const childNode = buildBlock(child, filePath, "logic", counter, errors)
                        return { id: ++counter.next, kind: "lift-expr", expr: { kind: "markup", node: childNode }, span: spanOf(startTok, refTok) }
                    }
                } else {
                    const result = collectLiftExpr()
                    return { id: ++counter.next, kind: "lift-expr", expr: { kind: "expr", expr: result.expr }, span: spanOf(startTok, peek()) }
                }
                return null
            }

            // FOR
            if (tok.kind == "KEYWORD" && tok.text == "for") {
                const startTok = consume()
                let variable = "item"
                if (peek().kind == "IDENT" || peek().kind == "KEYWORD") {
                    variable = consume().text
                }
                if (peek().kind == "KEYWORD" && peek().text == "in") {
                    consume()
                }
                const iterResult = collectExpr(OPEN_BRACE)
                let body = []
                if (peek().text == OPEN_BRACE) {
                    consume()
                    body = parseRecursiveBody()
                }
                return {
                    id: ++counter.next,
                    kind: "for-stmt",
                    variable,
                    iterable: iterResult.expr.trim(),
                    iterExpr: safeParseExprToNode(iterResult.expr.trim(), 0),
                    body,
                    span: spanOf(startTok, peek()),
                }
            }

            // IF
            if (tok.kind == "KEYWORD" && tok.text == "if") {
                return parseOneIfStmt()
            }

            // WHILE
            if (tok.kind == "KEYWORD" && tok.text == "while") {
                const startTok = consume()
                const condResult = collectExpr(OPEN_BRACE)
                let body = []
                if (peek().text == OPEN_BRACE) {
                    consume()
                    body = parseRecursiveBody()
                }
                return {
                    id: ++counter.next,
                    kind: "while-stmt",
                    condition: condResult.expr.trim(),
                    condExpr: safeParseExprToNode(condResult.expr.trim(), 0),
                    body,
                    span: spanOf(startTok, peek()),
                }
            }

            // RETURN
            if (tok.kind == "KEYWORD" && tok.text == "return") {
                const startTok = consume()
                const result = collectExpr()
                return {
                    id: ++counter.next,
                    kind: "return-stmt",
                    expr: result.expr.trim(),
                    exprNode: safeParseExprToNode(result.expr.trim(), 0),
                    span: spanOf(startTok, peek()),
                }
            }

            // THROW
            if (tok.kind == "KEYWORD" && tok.text == "throw") {
                const startTok = consume()
                const result = collectExpr()
                return {
                    id: ++counter.next,
                    kind: "throw-stmt",
                    expr: result.expr.trim(),
                    exprNode: safeParseExprToNode(result.expr.trim(), 0),
                    span: spanOf(startTok, peek()),
                }
            }

            // SWITCH / TRY / MATCH
            if (tok.kind == "KEYWORD" && (tok.text == "switch" || tok.text == "try" || tok.text == "match")) {
                const startTok = consume()
                const keyword = startTok.text
                const headerResult = collectExpr(OPEN_BRACE)
                let body = []
                if (peek().text == OPEN_BRACE) {
                    consume()
                    body = parseRecursiveBody()
                }
                const node = {
                    id: ++counter.next,
                    kind: keyword + "-stmt",
                    header: headerResult.expr.trim(),
                    headerExpr: safeParseExprToNode(headerResult.expr.trim(), 0),
                    body,
                    span: spanOf(startTok, peek()),
                }

                if (keyword == "try") {
                    if (peek().kind == "KEYWORD" && peek().text == "catch") {
                        consume()
                        const catchHeaderResult = collectExpr(OPEN_BRACE)
                        let catchBody = []
                        if (peek().text == OPEN_BRACE) {
                            consume()
                            catchBody = parseRecursiveBody()
                        }
                        node.catchNode = {
                            header: catchHeaderResult.expr.trim(),
                            body: catchBody,
                        }
                    }
                    if (peek().kind == "KEYWORD" && peek().text == "finally") {
                        consume()
                        const finallyHeaderResult = collectExpr(OPEN_BRACE)
                        let finallyBody = []
                        if (peek().text == OPEN_BRACE) {
                            consume()
                            finallyBody = parseRecursiveBody()
                        }
                        node.finallyNode = {
                            header: finallyHeaderResult.expr.trim(),
                            body: finallyBody,
                        }
                    }
                    node.span = spanOf(startTok, peek())
                }

                return node
            }

            // NESTED FUNCTION
            if (tok.kind == "KEYWORD" && tok.text == "function") {
                const startTok = consume()
                let isGenerator = false
                if (peek().text == "*") {
                    isGenerator = true
                    consume()
                }
                let name = ""
                if (peek().kind == "IDENT" || peek().kind == "KEYWORD") name = consume().text
                const params = parseParamList()
                let canFail = false
                if (peek().text == "!") {
                    consume()
                    canFail = true
                }
                let body = []
                if (peek().text == OPEN_BRACE) {
                    consume()
                    body = parseRecursiveBody()
                }
                return {
                    id: ++counter.next,
                    kind: "function-decl",
                    name,
                    params,
                    body,
                    fnKind: "function",
                    isServer: false,
                    isGenerator,
                    canFail,
                    span: spanOf(startTok, peek()),
                }
            }

            // TILDE-DECL
            if (tok.kind == "IDENT") {
                const nextTok = peek(1)
                if (nextTok && nextTok.kind == "PUNCT" && nextTok.text == "=" && peek(2) && peek(2).text != "=") {
                    const startTok = consume()
                    const name = startTok.text
                    consume()
                    const result = collectExpr()
                    return { id: ++counter.next, kind: "tilde-decl", name, init: result.expr, initExpr: safeParseExprToNode(result.expr, spanOf(startTok, peek())?.start ?? 0), span: spanOf(startTok, peek()) }
                }
            }

            // Default: bare-expr
            {
                const startTok2 = peek()
                const result = collectExpr()
                if (result.expr.trim().length > 0) {
                    return { id: ++counter.next, kind: "bare-expr", expr: result.expr, exprNode: safeParseExprToNode(result.expr, 0), span: result.span }
                } else {
                    const stuckTok = peek()
                    if (stuckTok.kind != "EOF") {
                        const stuckSpan = tokenSpan(stuckTok, filePath)
                        if (blockContext == "meta") {
                            errors.push(new TABError(
                                "E-META-002",
                                "E-META-002: `" + stuckTok.text + "` is not valid inside a `^" + String.fromCharCode(123) + " " + String.fromCharCode(125) + "` meta block. " +
                                "Meta blocks contain logic code, not direct markup. " +
                                "If you intended to emit markup here, use a `lift` expression: `lift <tag>...</tag>`.",
                                stuckSpan,
                            ))
                        } else {
                            errors.push(new TABError(
                                "E-PARSE-001",
                                "E-PARSE-001: `" + stuckTok.text + "` is not valid here. " +
                                "Inside a `$" + String.fromCharCode(123) + " " + String.fromCharCode(125) + "` logic block, the compiler expects a statement, a `let`/`const` declaration, an expression, or a `lift`. " +
                                "Check that any surrounding expression is complete and all brackets are balanced.",
                                stuckSpan,
                            ))
                        }
                        consume()
                    }
                    return null
                }
            }
        }

        // parseOneIfStmt
        function parseOneIfStmt() {
            const OPEN_BRACE = String.fromCharCode(123)
            const startTok = consume()
            const condResult = collectExpr(OPEN_BRACE)
            let consequent = []
            if (peek().text == OPEN_BRACE) {
                consume()
                consequent = parseRecursiveBody()
            }
            let alternate = null
            if (peek().kind == "KEYWORD" && peek().text == "else") {
                consume()
                if (peek().kind == "KEYWORD" && peek().text == "if") {
                    alternate = [parseOneIfStmt()]
                } else if (peek().text == OPEN_BRACE) {
                    consume()
                    alternate = parseRecursiveBody()
                }
            }
            return {
                id: ++counter.next,
                kind: "if-stmt",
                condition: condResult.expr.trim(),
                condExpr: safeParseExprToNode(condResult.expr.trim(), 0),
                consequent,
                alternate,
                span: spanOf(startTok, peek()),
            }
        }

        // parseParamList — §53: returns {name, typeAnnotation?} objects
        function parseParamList() {
            const OPEN_BRACE = String.fromCharCode(123)
            const CLOSE_BRACE = String.fromCharCode(125)
            const params = []
            if (peek().text != "(") return params
            consume()
            let depth = 1
            let cur = ""
            function pushParam(raw) {
                const s = raw.trim()
                if (!s) return
                const colonIdx = s.indexOf(":")
                if (colonIdx == -1) {
                    params.push({ name: s })
                } else {
                    const name = s.slice(0, colonIdx).trim()
                    const typeAnnotation = s.slice(colonIdx + 1).trim() || null
                    params.push({ name, typeAnnotation })
                }
            }
            while (true) {
                const tok = peek()
                if (tok.kind == "EOF") break
                if (tok.text == "(" || tok.text == "[" || tok.text == OPEN_BRACE) { depth++; cur += tok.text; consume() }
                else if (tok.text == ")" || tok.text == "]" || tok.text == CLOSE_BRACE) {
                    depth--
                    if (depth == 0) { consume(); break }
                    cur += tok.text
                    consume()
                } else if (tok.text == "," && depth == 1) {
                    pushParam(cur)
                    cur = ""
                    consume()
                } else {
                    cur += tok.text
                    consume()
                }
            }
            pushParam(cur)
            return params
        }

        // ---- Main while loop of parseLogicBody ----
        const OPEN_BRACE_MAIN = String.fromCharCode(123)
        const CLOSE_BRACE_MAIN = String.fromCharCode(125)

        while (true) {
            const tok = peek()
            if (tok.kind == "EOF") break

            if (tok.kind == "COMMENT") { consume(); continue }
            if (tok.kind == "PUNCT" && tok.text == ";") { consume(); continue }
            if (tok.text.trim() == "" && tok.kind != "EOF") { consume(); continue }

            // GUARDED-EXPR (outer loop)
            if (tok.kind == "BLOCK_REF" && tok.block && tok.block.type == "error-effect" && nodes.length > 0) {
                consume()
                const errBlock = buildBlock(tok.block, filePath, parentBlock.type, counter, errors)
                const lastNode = nodes[nodes.length - 1]
                nodes[nodes.length - 1] = {
                    id: ++counter.next,
                    kind: "guarded-expr",
                    guardedNode: lastNode,
                    arms: errBlock ? errBlock.arms : [],
                    span: { ...lastNode.span, end: tok.block.span.end },
                }
                continue
            }

            // BLOCK_REF
            if (tok.kind == "BLOCK_REF") {
                consume()
                const child = tok.block
                if (child) {
                    const childNode = buildBlock(child, filePath, parentBlock.type, counter, errors)
                    if (childNode) {
                        childNode.span = fullSpan(child.span, filePath)
                        if (childNode.kind == "sql" && childNode.chainedCalls) {
                            while (peek().kind == "PUNCT" && peek().text == ".") {
                                consume()
                                if (peek().kind == "IDENT") {
                                    const methodTok = consume()
                                    let args = ""
                                    if (peek().kind == "PUNCT" && peek().text == "(") {
                                        consume()
                                        while (peek().kind != "EOF" && !(peek().kind == "PUNCT" && peek().text == ")")) {
                                            args += consume().text
                                        }
                                        if (peek().kind == "PUNCT" && peek().text == ")") consume()
                                    }
                                    childNode.chainedCalls.push({ method: methodTok.text, args })
                                }
                            }
                        }
                        nodes.push(childNode)
                    }
                }
                continue
            }

            // IMPORT
            if (tok.kind == "KEYWORD" && tok.text == "import") {
                const startTok = consume()
                const result = collectExpr()
                const rawStr = "import " + result.expr

                const importNode = { id: ++counter.next, kind: "import-decl", raw: rawStr, span: result.span, names: [], source: null, isDefault: false }

                const namedMatch = result.expr.match(new RegExp("^\\s*" + String.fromCharCode(123) + "\\s*([^" + String.fromCharCode(125) + "]*)" + String.fromCharCode(125) + "\\s*from\\s+[\"']([^\"']+)[\"']"))
                if (namedMatch) {
                    importNode.names = namedMatch[1].split(",").map(function(s) { return s.trim() }).filter(Boolean)
                    importNode.source = namedMatch[2]
                } else {
                    const defaultMatch = result.expr.match(/^\s*(\w+)\s+from\s+["']([^"']+)["']/)
                    if (defaultMatch) {
                        importNode.names = [defaultMatch[1]]
                        importNode.source = defaultMatch[2]
                        importNode.isDefault = true
                    }
                }

                nodes.push(importNode)
                continue
            }

            // USE
            if (tok.kind == "KEYWORD" && tok.text == "use") {
                const startTok = consume()
                const result = collectExpr()
                const rawStr = "use " + result.expr

                const useNode = { id: ++counter.next, kind: "use-decl", raw: rawStr, span: result.span, names: [], source: null }

                const namedMatch = result.expr.match(new RegExp("^\\s*([\\w:/.@-]+)\\s*" + String.fromCharCode(123) + "\\s*([^" + String.fromCharCode(125) + "]*)" + String.fromCharCode(125)))
                if (namedMatch) {
                    useNode.source = namedMatch[1].trim()
                    useNode.names = namedMatch[2].split(",").map(function(s) { return s.trim() }).filter(Boolean)
                } else {
                    const sourceOnly = result.expr.match(/^\s*([\w:/.@-]+)\s*$/)
                    if (sourceOnly) {
                        useNode.source = sourceOnly[1].trim()
                    }
                }

                nodes.push(useNode)
                continue
            }

            // EXPORT
            if (tok.kind == "KEYWORD" && tok.text == "export") {
                const startTok = consume()
                const result = collectExpr()
                const rawStr = "export " + result.expr

                const exportNode = { id: ++counter.next, kind: "export-decl", raw: rawStr, span: result.span, exportedName: null, exportKind: null, reExportSource: null }

                const reExportMatch = result.expr.match(new RegExp("^\\s*" + String.fromCharCode(123) + "\\s*([^" + String.fromCharCode(125) + "]*)" + String.fromCharCode(125) + "\\s*from\\s+[\"']([^\"']+)[\"']"))
                if (reExportMatch) {
                    exportNode.exportedName = reExportMatch[1].split(",").map(function(s) { return s.trim() }).filter(Boolean).join(", ")
                    exportNode.exportKind = "re-export"
                    exportNode.reExportSource = reExportMatch[2]
                } else {
                    const declMatch = result.expr.match(/^\s*(type|function|fn|const|let)\s+(\w+)/)
                    if (declMatch) {
                        exportNode.exportKind = declMatch[1]
                        exportNode.exportedName = declMatch[2]
                    }
                }

                nodes.push(exportNode)
                continue
            }

            // TYPE DECLARATION
            if (tok.kind == "KEYWORD" && tok.text == "type") {
                const startTok = consume()

                let typeName = ""
                let typeKind = ""

                if (peek().kind == "IDENT" || peek().kind == "KEYWORD") {
                    typeName = consume().text
                }

                if (peek().text == ":") {
                    consume()
                    typeKind = (peek().kind == "IDENT" || peek().kind == "KEYWORD")
                        ? consume().text
                        : ""
                }

                let raw = ""
                if (peek().text == "=") {
                    consume()
                    if (peek().text == OPEN_BRACE_MAIN) {
                        consume()
                        const bracedResult = collectBracedBody()
                        raw = "{ " + bracedResult.body + " }"
                        nodes.push({
                            id: ++counter.next,
                            kind: "type-decl",
                            name: typeName,
                            typeKind,
                            raw,
                            span: spanOf(startTok, peek()),
                        })
                    } else {
                        const exprResult = collectExpr()
                        raw = exprResult.expr
                        nodes.push({
                            id: ++counter.next,
                            kind: "type-decl",
                            name: typeName,
                            typeKind,
                            raw,
                            span: spanOf(startTok, peek()),
                        })
                    }
                } else {
                    nodes.push({
                        id: ++counter.next,
                        kind: "type-decl",
                        name: typeName,
                        typeKind,
                        raw: "",
                        span: tokenSpan(startTok, filePath),
                    })
                }
                continue
            }

            // @debounced(N)
            if (tok.kind == "AT_IDENT" && tok.text == "@debounced") {
                const startTok = consume()
                let delay = 300
                if (peek().text == "(") {
                    consume()
                    const delayParts = []
                    while (peek().text != ")" && peek().kind != "EOF") {
                        delayParts.push(consume().text)
                    }
                    if (peek().text == ")") consume()
                    delay = parseInt(delayParts.join("").trim(), 10) || 300
                }
                let name = ""
                if (peek().kind == "IDENT" || peek().kind == "KEYWORD") {
                    name = consume().text
                }
                if (peek().text == "=" && peek(1) && peek(1).text != "=") {
                    consume()
                    const result = collectExpr()
                    nodes.push({
                        id: ++counter.next,
                        kind: "reactive-debounced-decl",
                        name,
                        init: result.expr,
                        delay,
                        span: spanOf(startTok, peek()),
                    })
                } else {
                    const result = collectExpr()
                    nodes.push({
                        id: ++counter.next,
                        kind: "bare-expr",
                        expr: startTok.text + " " + name + (result.expr ? " " + result.expr : ""),
                        span: spanOf(startTok, peek()),
                    })
                }
                continue
            }

            // @shared
            if (tok.kind == "AT_IDENT" && tok.text == "@shared") {
                const startTok = consume()
                if ((peek().kind == "IDENT" || peek().kind == "KEYWORD") && peek(1) && peek(1).text == "=" && peek(2) && peek(2).text != "=") {
                    const nameTok = consume()
                    consume()
                    const result = collectExpr()
                    nodes.push({ id: ++counter.next, kind: "state-decl", name: nameTok.text, init: result.expr, isShared: true, shape: "plain", structuralForm: false, isConst: false, span: spanOf(startTok, peek()) })
                    continue
                }
                const result = collectExpr()
                nodes.push({ id: ++counter.next, kind: "bare-expr", expr: startTok.text + (result.expr ? " " + result.expr : ""), span: spanOf(startTok, peek()) })
                continue
            }

            // REACTIVE DECLARATION / NESTED ASSIGN / ARRAY MUTATION
            if (tok.kind == "AT_IDENT") {
                const startTok = consume()
                const name = tok.text.slice(1)

                if (peek().text == ".") {
                    const pathSegments = []
                    const tempTokens = []

                    while (peek().text == ".") {
                        const dotTok = consume()
                        tempTokens.push(dotTok)
                        if (peek().kind == "IDENT" || peek().kind == "KEYWORD") {
                            const segTok = consume()
                            tempTokens.push(segTok)
                            pathSegments.push(segTok.text)
                        } else {
                            break
                        }
                    }

                    const ARRAY_MUTATIONS = ["push", "pop", "shift", "unshift", "splice", "sort", "reverse", "fill"]
                    const lastSeg = pathSegments[pathSegments.length - 1]
                    if (pathSegments.length == 1 && ARRAY_MUTATIONS.includes(lastSeg) && peek().text == "(") {
                        consume()
                        const argParts = []
                        let parenDepth = 1
                        while (parenDepth > 0 && peek().kind != "EOF") {
                            const t = consume()
                            if (t.text == "(") parenDepth++
                            if (t.text == ")") { parenDepth--; if (parenDepth == 0) break }
                            argParts.push(t.text)
                        }
                        nodes.push({
                            id: ++counter.next,
                            kind: "reactive-array-mutation",
                            target: name,
                            method: lastSeg,
                            args: argParts.join(" ").trim(),
                            span: spanOf(startTok, peek()),
                        })
                        continue
                    }

                    if (peek().text == "=" && peek(1) && peek(1).text != "=") {
                        consume()
                        const result = collectExpr()
                        nodes.push({
                            id: ++counter.next,
                            kind: "reactive-nested-assign",
                            target: name,
                            path: pathSegments,
                            value: result.expr,
                            valueExpr: safeParseExprToNode(result.expr, 0),
                            span: spanOf(startTok, peek()),
                        })
                        continue
                    }

                    const pathStr = "." + pathSegments.join(".")
                    const result = collectExpr()
                    nodes.push({
                        id: ++counter.next,
                        kind: "bare-expr",
                        expr: startTok.text + pathStr + (result.expr ? " " + result.expr : ""),
                        span: spanOf(startTok, peek()),
                    })
                    continue
                }

                // Simple reactive decl
                if (peek().text == "=" && peek(1) && peek(1).text != "=") {
                    consume()
                    const result = collectExpr()
                    nodes.push({
                        id: ++counter.next,
                        kind: "state-decl",
                        name,
                        init: result.expr,
                        shape: "plain",
                        structuralForm: false,
                        isConst: false,
                        span: spanOf(startTok, peek()),
                    })
                    continue
                }

                // @set
                if (name == "set" && peek().text == "(") {
                    consume()
                    const argParts = []
                    let parenDepth = 1
                    while (parenDepth > 0 && peek().kind != "EOF") {
                        const t = consume()
                        if (t.text == "(") parenDepth++
                        if (t.text == ")") { parenDepth--; if (parenDepth == 0) break }
                        argParts.push(t.text)
                    }
                    nodes.push({
                        id: ++counter.next,
                        kind: "reactive-explicit-set",
                        args: argParts.join(" ").trim(),
                        span: spanOf(startTok, peek()),
                    })
                    continue
                }

                const result = collectExpr()
                nodes.push({
                    id: ++counter.next,
                    kind: "bare-expr",
                    expr: startTok.text + (result.expr ? " " + result.expr : ""),
                    span: spanOf(startTok, peek()),
                })
                continue
            }

            // LET DECLARATION
            if (tok.kind == "KEYWORD" && tok.text == "let") {
                const startTok = consume()
                let name = ""
                if (peek().kind == "IDENT") name = consume().text
                else if (peek().kind == "KEYWORD") name = consume().text

                if (peek().text == "=" && peek(1) && peek(1).text != "=") {
                    consume()
                    const result = collectExpr()
                    const stripped = result.expr.trimEnd()
                    if (stripped.endsWith("?")) {
                        const innerExpr = stripped.slice(0, -1).trimEnd()
                        nodes.push({
                            id: ++counter.next,
                            kind: "propagate-expr",
                            binding: name,
                            expr: innerExpr,
                            exprNode: safeParseExprToNode(innerExpr, 0),
                            span: spanOf(startTok, peek()),
                        })
                    } else {
                        nodes.push({
                            id: ++counter.next,
                            kind: "let-decl",
                            name,
                            init: result.expr,
                            span: spanOf(startTok, peek()),
                        })
                    }
                } else {
                    const result = collectExpr()
                    nodes.push({
                        id: ++counter.next,
                        kind: "let-decl",
                        name,
                        init: result.expr,
                        span: spanOf(startTok, peek()),
                    })
                }
                continue
            }

            // CONST DECLARATION
            if (tok.kind == "KEYWORD" && tok.text == "const") {
                const startTok = consume()

                if (peek().kind == "AT_IDENT") {
                    const atTok = consume()
                    const derivedName = atTok.text.slice(1)
                    if (peek().text == "=" && peek(1) && peek(1).text != "=") {
                        consume()
                        const result = collectExpr()
                        nodes.push({
                            id: ++counter.next,
                            kind: "reactive-derived-decl",
                            name: derivedName,
                            init: result.expr,
                            span: spanOf(startTok, peek()),
                        })
                    } else {
                        nodes.push({
                            id: ++counter.next,
                            kind: "reactive-derived-decl",
                            name: derivedName,
                            init: "",
                            span: spanOf(startTok, peek()),
                        })
                    }
                    continue
                }

                let name = ""
                if (peek().kind == "IDENT" || peek().kind == "KEYWORD") name = consume().text

                if (peek().text == "=" && peek(1) && peek(1).text != "=") {
                    consume()
                    const result = collectExpr()
                    // Component-def requires BOTH uppercase-initial name AND markup RHS.
                    // `const ASCII_WS = new Set(...)` must parse as const-decl, not
                    // component-def (the latter would vacuum sibling decls into defChildren).
                    const exprStartsWithMarkup = typeof result.expr == "string" && result.expr.trimStart().startsWith("<")
                    if (blockContext != "meta" && exprStartsWithMarkup && name && name[0] == name[0].toUpperCase() && name[0] != name[0].toLowerCase()) {
                        nodes.push({
                            id: ++counter.next,
                            kind: "component-def",
                            name,
                            raw: result.expr,
                            span: spanOf(startTok, peek()),
                        })
                    } else {
                        nodes.push({
                            id: ++counter.next,
                            kind: "const-decl",
                            name,
                            init: result.expr,
                            span: spanOf(startTok, peek()),
                        })
                    }
                } else {
                    nodes.push({
                        id: ++counter.next,
                        kind: "const-decl",
                        name,
                        init: "",
                        span: tokenSpan(startTok, filePath),
                    })
                }
                continue
            }

            // LIFT STATEMENT
            if (tok.kind == "KEYWORD" && tok.text == "lift") {
                const startTok = consume()

                if (peek().kind == "BLOCK_REF") {
                    const refTok = consume()
                    const child = refTok.block
                    if (child) {
                        const childNode = buildBlock(child, filePath, "logic", counter, errors)
                        nodes.push({
                            id: ++counter.next,
                            kind: "lift-expr",
                            expr: { kind: "markup", node: childNode },
                            span: spanOf(startTok, refTok),
                        })
                    }
                } else {
                    const result = collectLiftExpr()
                    nodes.push({
                        id: ++counter.next,
                        kind: "lift-expr",
                        expr: { kind: "expr", expr: result.expr },
                        span: spanOf(startTok, peek()),
                    })
                }
                continue
            }

            // FAIL EXPRESSION
            if (tok.kind == "KEYWORD" && tok.text == "fail") {
                const startTok = consume()

                let enumType = ""
                let variant = ""
                let args = ""

                if (peek().kind == "IDENT" || peek().kind == "KEYWORD") {
                    enumType = consume().text
                }

                if (peek().text == "::") {
                    consume()
                    if (peek().kind == "IDENT" || peek().kind == "KEYWORD") {
                        variant = consume().text
                    }
                }

                if (peek().text == "(") {
                    consume()
                    const argParts = []
                    let depth = 1
                    while (depth > 0) {
                        const t = peek()
                        if (t.kind == "EOF") break
                        if (t.text == "(") depth++
                        if (t.text == ")") {
                            depth--
                            if (depth == 0) { consume(); break }
                        }
                        argParts.push(consume().text)
                    }
                    args = argParts.join(" ")
                }

                nodes.push({
                    id: ++counter.next,
                    kind: "fail-expr",
                    enumType,
                    variant,
                    args,
                    span: spanOf(startTok, peek()),
                })
                continue
            }

            // FUNCTION DECLARATION
            if (
                tok.kind == "KEYWORD" && tok.text == "function" ||
                (tok.kind == "KEYWORD" && tok.text == "server" && peek(1).kind == "KEYWORD" && peek(1).text == "function")
            ) {
                let isServer = false
                let startTok = tok

                if (tok.text == "server") {
                    isServer = true
                    startTok = consume()
                }
                consume()

                let isGenerator = false
                if (peek().text == "*") {
                    isGenerator = true
                    consume()
                }

                let name = ""
                if (peek().kind == "IDENT" || peek().kind == "KEYWORD") name = consume().text

                const params = parseParamList()

                let canFail = false
                let errorType = undefined
                if (peek().text == "!") {
                    consume()
                    canFail = true
                    if (peek().text == "-" && peek(1) && peek(1).text == ">") {
                        consume()
                        consume()
                        if (peek().kind == "IDENT" || peek().kind == "KEYWORD") {
                            errorType = consume().text
                        }
                    }
                }

                let route = undefined
                let method = undefined
                while (peek().kind == "IDENT" && (peek().text == "route" || peek().text == "method")) {
                    const attrName = consume().text
                    if (peek().text == "=") {
                        consume()
                        if (peek().kind == "STRING") {
                            const value = consume().text
                            if (attrName == "route") route = value
                            else if (attrName == "method") method = value
                        }
                    }
                }

                let body = []
                if (peek().text == OPEN_BRACE_MAIN) {
                    consume()
                    body = parseRecursiveBody()
                }

                nodes.push({
                    id: ++counter.next,
                    kind: "function-decl",
                    name,
                    params,
                    body,
                    fnKind: "function",
                    isServer,
                    isGenerator,
                    canFail,
                    errorType,
                    route,
                    method,
                    isHandleEscapeHatch: isServer && !isGenerator && name == "handle",
                    span: spanOf(startTok, peek()),
                })
                continue
            }

            // FN SHORTHAND
            if (
                tok.kind == "KEYWORD" && tok.text == "fn" ||
                (tok.kind == "KEYWORD" && tok.text == "server" && peek(1).kind == "KEYWORD" && peek(1).text == "fn")
            ) {
                if (blockContext != "logic") {
                    errors.push(new TABError(
                        "E-PARSE-002",
                        "E-PARSE-002: `fn` can only be used inside a `$" + String.fromCharCode(123) + " " + String.fromCharCode(125) + "` logic block. " +
                        "Here it appears inside a " + contextLabel(blockContext) + " block, where it is not valid. " +
                        "Use a standard `function` declaration instead, or move the function definition into a `$" + String.fromCharCode(123) + " " + String.fromCharCode(125) + "` block.",
                        tokenSpan(tok, filePath),
                    ))
                }

                let isServer = false
                let startTok = tok

                if (tok.text == "server") {
                    isServer = true
                    startTok = consume()
                }
                consume()

                let name = ""
                if (peek().kind == "IDENT" || peek().kind == "KEYWORD") name = consume().text

                let params = []
                if (peek().text == "(") {
                    params = parseParamList()
                }

                let canFail = false
                let errorType = undefined
                if (peek().text == "!") {
                    consume()
                    canFail = true
                    if (peek().text == "-" && peek(1) && peek(1).text == ">") {
                        consume()
                        consume()
                        if (peek().kind == "IDENT" || peek().kind == "KEYWORD") {
                            errorType = consume().text
                        }
                    }
                }

                let body = []
                if (peek().text == OPEN_BRACE_MAIN) {
                    consume()
                    body = parseRecursiveBody()
                }

                nodes.push({
                    id: ++counter.next,
                    kind: "function-decl",
                    name,
                    params,
                    body,
                    fnKind: "fn",
                    isServer,
                    canFail,
                    errorType,
                    span: spanOf(startTok, peek()),
                })
                continue
            }

            // FOR STATEMENT
            if (tok.kind == "KEYWORD" && tok.text == "for") {
                const startTok = consume()
                let variable = "item"
                if (peek().kind == "IDENT" || peek().kind == "KEYWORD") {
                    variable = consume().text
                }
                if (peek().kind == "KEYWORD" && peek().text == "in") {
                    consume()
                }
                const iterResult = collectExpr(OPEN_BRACE_MAIN)
                let body = []
                if (peek().text == OPEN_BRACE_MAIN) {
                    consume()
                    body = parseRecursiveBody()
                }
                nodes.push({
                    id: ++counter.next,
                    kind: "for-stmt",
                    variable,
                    iterable: iterResult.expr.trim(),
                    iterExpr: safeParseExprToNode(iterResult.expr.trim(), 0),
                    body,
                    span: spanOf(startTok, peek()),
                })
                continue
            }

            // IF STATEMENT
            if (tok.kind == "KEYWORD" && tok.text == "if") {
                const node = parseOneIfStmt()
                if (node) nodes.push(node)
                continue
            }

            // WHILE STATEMENT
            if (tok.kind == "KEYWORD" && tok.text == "while") {
                const startTok = consume()
                const condResult = collectExpr(OPEN_BRACE_MAIN)
                let body = []
                if (peek().text == OPEN_BRACE_MAIN) {
                    consume()
                    body = parseRecursiveBody()
                }
                nodes.push({
                    id: ++counter.next,
                    kind: "while-stmt",
                    condition: condResult.expr.trim(),
                    condExpr: safeParseExprToNode(condResult.expr.trim(), 0),
                    body,
                    span: spanOf(startTok, peek()),
                })
                continue
            }

            // RETURN STATEMENT
            if (tok.kind == "KEYWORD" && tok.text == "return") {
                const startTok = consume()
                const result = collectExpr()
                nodes.push({
                    id: ++counter.next,
                    kind: "return-stmt",
                    expr: result.expr.trim(),
                    exprNode: safeParseExprToNode(result.expr.trim(), 0),
                    span: spanOf(startTok, peek()),
                })
                continue
            }

            // THROW STATEMENT
            if (tok.kind == "KEYWORD" && tok.text == "throw") {
                const startTok = consume()
                const result = collectExpr()
                nodes.push({
                    id: ++counter.next,
                    kind: "throw-stmt",
                    expr: result.expr.trim(),
                    exprNode: safeParseExprToNode(result.expr.trim(), 0),
                    span: spanOf(startTok, peek()),
                })
                continue
            }

            // SWITCH / TRY / MATCH
            if (tok.kind == "KEYWORD" && (tok.text == "switch" || tok.text == "try" || tok.text == "match")) {
                const startTok = consume()
                const keyword = startTok.text
                const headerResult = collectExpr(OPEN_BRACE_MAIN)
                let body = []
                if (peek().text == OPEN_BRACE_MAIN) {
                    consume()
                    body = parseRecursiveBody()
                }
                const node = {
                    id: ++counter.next,
                    kind: keyword + "-stmt",
                    header: headerResult.expr.trim(),
                    headerExpr: safeParseExprToNode(headerResult.expr.trim(), 0),
                    body,
                    span: spanOf(startTok, peek()),
                }

                if (keyword == "try") {
                    if (peek().kind == "KEYWORD" && peek().text == "catch") {
                        consume()
                        const catchHeaderResult = collectExpr(OPEN_BRACE_MAIN)
                        let catchBody = []
                        if (peek().text == OPEN_BRACE_MAIN) {
                            consume()
                            catchBody = parseRecursiveBody()
                        }
                        node.catchNode = {
                            header: catchHeaderResult.expr.trim(),
                            body: catchBody,
                        }
                    }
                    if (peek().kind == "KEYWORD" && peek().text == "finally") {
                        consume()
                        const finallyHeaderResult = collectExpr(OPEN_BRACE_MAIN)
                        let finallyBody = []
                        if (peek().text == OPEN_BRACE_MAIN) {
                            consume()
                            finallyBody = parseRecursiveBody()
                        }
                        node.finallyNode = {
                            header: finallyHeaderResult.expr.trim(),
                            body: finallyBody,
                        }
                    }
                    node.span = spanOf(startTok, peek())
                }

                nodes.push(node)
                continue
            }

            // TRANSACTION BLOCK
            if (tok.kind == "KEYWORD" && tok.text == "transaction") {
                const startTok = consume()
                let body = []
                if (peek().text == OPEN_BRACE_MAIN) {
                    consume()
                    body = parseRecursiveBody()
                }
                nodes.push({
                    id: ++counter.next,
                    kind: "transaction-block",
                    body,
                    span: spanOf(startTok, peek()),
                })
                continue
            }

            // CLEANUP
            if (tok.kind == "KEYWORD" && tok.text == "cleanup") {
                const startTok = consume()
                if (peek().text == "(") {
                    consume()
                    const callbackParts = []
                    let depth = 1
                    let lastTok2 = peek()
                    while (depth > 0) {
                        const t = peek()
                        if (t.kind == "EOF") break
                        if (t.text == "(") depth++
                        if (t.text == ")") {
                            depth--
                            if (depth == 0) { lastTok2 = consume(); break }
                        }
                        lastTok2 = consume()
                        if (lastTok2.kind == "STRING") {
                            callbackParts.push('"' + lastTok2.text.replace(/\\/g, "\\\\").replace(/"/g, '\\"') + '"')
                        } else {
                            callbackParts.push(lastTok2.text)
                        }
                    }
                    if (peek().kind == "PUNCT" && peek().text == ";") consume()
                    nodes.push({
                        id: ++counter.next,
                        kind: "cleanup-registration",
                        callback: callbackParts.join(" "),
                        span: spanOf(startTok, lastTok2),
                    })
                }
                continue
            }

            // WHEN reactive effect
            if (tok.kind == "KEYWORD" && tok.text == "when") {
                const startTok = consume()
                const dependencies = []

                if (peek().text == "(") {
                    consume()
                    while (peek().text != ")" && peek().kind != "EOF") {
                        if (peek().kind == "AT_IDENT") {
                            dependencies.push(consume().text.replace(/^@/, ""))
                        } else if (peek().text == ",") {
                            consume()
                        } else {
                            consume()
                        }
                    }
                    if (peek().text == ")") consume()
                } else if (peek().kind == "AT_IDENT") {
                    dependencies.push(consume().text.replace(/^@/, ""))
                }

                if (peek().kind == "KEYWORD" && peek().text == "changes") {
                    consume()
                }

                const bodyNodes = []
                if (peek().text == OPEN_BRACE_MAIN) {
                    consume()
                    let depth = 1
                    const bodyParts = []
                    let lastTok2 = peek()
                    while (depth > 0 && peek().kind != "EOF") {
                        const t = peek()
                        if (t.text == OPEN_BRACE_MAIN) depth++
                        if (t.text == CLOSE_BRACE_MAIN) {
                            depth--
                            if (depth == 0) { lastTok2 = consume(); break }
                        }
                        lastTok2 = consume()
                        if (lastTok2.kind == "STRING") {
                            bodyParts.push('"' + lastTok2.text.replace(/\\/g, "\\\\").replace(/"/g, '\\"') + '"')
                        } else {
                            bodyParts.push(lastTok2.text)
                        }
                    }
                    if (bodyParts.length > 0) {
                        bodyNodes.push(bodyParts.join(" "))
                    }

                    nodes.push({
                        id: ++counter.next,
                        kind: "when-effect",
                        dependencies,
                        bodyRaw: bodyParts.join(" "),
                        span: spanOf(startTok, lastTok2),
                    })
                }
                continue
            }

            // UPLOAD
            if (tok.kind == "KEYWORD" && tok.text == "upload") {
                const startTok = consume()
                if (peek().text == "(") {
                    consume()
                    const fileParts = []
                    let depth = 1
                    let lastTok2 = peek()
                    while (true) {
                        const t = peek()
                        if (t.kind == "EOF") break
                        if (t.text == "(") depth++
                        if (t.text == ")") {
                            depth--
                            if (depth == 0) { lastTok2 = consume(); break }
                        }
                        if (t.text == "," && depth == 1) { consume(); break }
                        lastTok2 = consume()
                        fileParts.push(lastTok2.text)
                    }
                    const urlParts = []
                    depth = 1
                    while (depth > 0) {
                        const t = peek()
                        if (t.kind == "EOF") break
                        if (t.text == "(") depth++
                        if (t.text == ")") {
                            depth--
                            if (depth == 0) { lastTok2 = consume(); break }
                        }
                        lastTok2 = consume()
                        if (lastTok2.kind == "STRING") {
                            urlParts.push('"' + lastTok2.text.replace(/\\/g, "\\\\").replace(/"/g, '\\"') + '"')
                        } else {
                            urlParts.push(lastTok2.text)
                        }
                    }
                    if (peek().kind == "PUNCT" && peek().text == ";") consume()
                    nodes.push({
                        id: ++counter.next,
                        kind: "upload-call",
                        file: fileParts.join(" ").trim(),
                        url: urlParts.join(" ").trim(),
                        span: spanOf(startTok, lastTok2),
                    })
                }
                continue
            }

            // DEBOUNCE
            if (tok.kind == "KEYWORD" && tok.text == "debounce") {
                const startTok = consume()
                if (peek().text == "(") {
                    consume()
                    const fnParts = []
                    let depth = 1
                    let lastTok2 = peek()
                    while (true) {
                        const t = peek()
                        if (t.kind == "EOF") break
                        if (t.text == "(") depth++
                        if (t.text == ")") {
                            depth--
                            if (depth == 0) { lastTok2 = consume(); break }
                        }
                        if (t.text == "," && depth == 1) { consume(); break }
                        lastTok2 = consume()
                        fnParts.push(lastTok2.text)
                    }
                    const delayParts = []
                    depth = 1
                    while (depth > 0) {
                        const t = peek()
                        if (t.kind == "EOF") break
                        if (t.text == "(") depth++
                        if (t.text == ")") {
                            depth--
                            if (depth == 0) { lastTok2 = consume(); break }
                        }
                        lastTok2 = consume()
                        delayParts.push(lastTok2.text)
                    }
                    if (peek().kind == "PUNCT" && peek().text == ";") consume()
                    nodes.push({
                        id: ++counter.next,
                        kind: "debounce-call",
                        fn: fnParts.join(" ").trim(),
                        delay: parseInt(delayParts.join("").trim(), 10) || 300,
                        span: spanOf(startTok, lastTok2),
                    })
                }
                continue
            }

            // THROTTLE
            if (tok.kind == "KEYWORD" && tok.text == "throttle") {
                const startTok = consume()
                if (peek().text == "(") {
                    consume()
                    const fnParts = []
                    let depth = 1
                    let lastTok2 = peek()
                    while (true) {
                        const t = peek()
                        if (t.kind == "EOF") break
                        if (t.text == "(") depth++
                        if (t.text == ")") {
                            depth--
                            if (depth == 0) { lastTok2 = consume(); break }
                        }
                        if (t.text == "," && depth == 1) { consume(); break }
                        lastTok2 = consume()
                        fnParts.push(lastTok2.text)
                    }
                    const delayParts = []
                    depth = 1
                    while (depth > 0) {
                        const t = peek()
                        if (t.kind == "EOF") break
                        if (t.text == "(") depth++
                        if (t.text == ")") {
                            depth--
                            if (depth == 0) { lastTok2 = consume(); break }
                        }
                        lastTok2 = consume()
                        delayParts.push(lastTok2.text)
                    }
                    if (peek().kind == "PUNCT" && peek().text == ";") consume()
                    nodes.push({
                        id: ++counter.next,
                        kind: "throttle-call",
                        fn: fnParts.join(" ").trim(),
                        delay: parseInt(delayParts.join("").trim(), 10) || 100,
                        span: spanOf(startTok, lastTok2),
                    })
                }
                continue
            }

            // TILDE-DECL
            if (tok.kind == "IDENT") {
                const nextTok = peek(1)
                if (nextTok && nextTok.kind == "PUNCT" && nextTok.text == "=" && peek(2) && peek(2).text != "=") {
                    const startTok = consume()
                    const name = startTok.text
                    consume()
                    const result = collectExpr()
                    nodes.push({ id: ++counter.next, kind: "tilde-decl", name, init: result.expr, span: spanOf(startTok, peek()) })
                    continue
                }
            }

            // Anything else: BareExpr
            {
                const startTok2 = peek()
                const result = collectExpr()
                if (result.expr.trim().length > 0) {
                    const stripped = result.expr.trimEnd()
                    if (stripped.endsWith("?")) {
                        const innerExpr = stripped.slice(0, -1).trimEnd()
                        nodes.push({
                            id: ++counter.next,
                            kind: "propagate-expr",
                            binding: null,
                            expr: innerExpr,
                            exprNode: safeParseExprToNode(innerExpr, 0),
                            span: result.span,
                        })
                    } else {
                        nodes.push({ id: ++counter.next, kind: "bare-expr", expr: result.expr, exprNode: safeParseExprToNode(result.expr, 0), span: result.span })
                    }
                } else {
                    const stuckTok = peek()
                    if (stuckTok.kind != "EOF") {
                        const stuckSpan = tokenSpan(stuckTok, filePath)
                        if (blockContext == "meta") {
                            errors.push(new TABError(
                                "E-META-002",
                                "E-META-002: `" + stuckTok.text + "` is not valid inside a `^" + String.fromCharCode(123) + " " + String.fromCharCode(125) + "` meta block. " +
                                "Meta blocks contain logic code, not direct markup. " +
                                "If you intended to emit markup here, use a `lift` expression: `lift <tag>...</tag>`.",
                                stuckSpan,
                            ))
                        } else {
                            errors.push(new TABError(
                                "E-PARSE-001",
                                "E-PARSE-001: `" + stuckTok.text + "` is not valid here. " +
                                "Inside a `$" + String.fromCharCode(123) + " " + String.fromCharCode(125) + "` logic block, the compiler expects a statement, a `let`/`const` declaration, an expression, or a `lift`. " +
                                "Check that any surrounding expression is complete and all brackets are balanced.",
                                stuckSpan,
                            ))
                        }
                        consume()
                    }
                }
            }
        }

        return nodes
    }

    // ---------------------------------------------------------------------------
    // SQL block parser
    // ---------------------------------------------------------------------------

    fn parseSQLTokens(tokens, filePath) {
        let query = ""
        const chainedCalls = []
        let i = 0

        if (i < tokens.length && tokens[i].kind == "SQL_RAW") {
            query = tokens[i].text
            i++
        }

        while (i < tokens.length && tokens[i].kind != "EOF") {
            const tok = tokens[i]
            if (tok.kind == "IDENT") {
                const methodName = tok.text
                i++
                if (i < tokens.length && tokens[i].kind == "PUNCT" && tokens[i].text == "(") i++
                let args = ""
                if (i < tokens.length && tokens[i].kind == "SQL_ARGS") {
                    args = tokens[i].text
                    i++
                }
                if (i < tokens.length && tokens[i].kind == "PUNCT" && tokens[i].text == ")") i++
                chainedCalls.push({
                    method: methodName,
                    args,
                    span: tokenSpan(tok, filePath),
                })
            } else {
                i++
            }
        }

        return { query, chainedCalls }
    }

    // ---------------------------------------------------------------------------
    // CSS block parser
    // ---------------------------------------------------------------------------

    fn scanCSSValueForReactiveRefs(value) {
        const AT_IDENT_RE = /@([A-Za-z_$][A-Za-z0-9_$]*)/g
        const refs = []
        const seenNames = new Set()
        let match

        while ((match = AT_IDENT_RE.exec(value)) != null) {
            const name = match[1]
            if (!seenNames.has(name)) {
                seenNames.add(name)
                refs.push({ name })
            }
        }

        if (refs.length == 0) return { refs: [], isExpression: false }

        const trimmed = value.trim()
        const simpleRefRe = /^@[A-Za-z_$][A-Za-z0-9_$]*(\s+[A-Za-z%]+)?$/
        const isExpression = !simpleRefRe.test(trimmed)

        if (isExpression) {
            for (const ref of refs) {
                ref.expr = trimmed
            }
        } else {
            for (const ref of refs) {
                ref.expr = null
            }
        }

        return { refs, isExpression }
    }

    fn parseCSSTokens(tokens, filePath) {
        const OPEN_BRACE = String.fromCharCode(123)
        const CLOSE_BRACE = String.fromCharCode(125)
        const rules = []
        let i = 0

        while (i < tokens.length && tokens[i].kind != "EOF") {
            const tok = tokens[i]
            if (tok.kind == "CSS_PROP") {
                const prop = tok.text
                const startSpan = tokenSpan(tok, filePath)
                i++
                if (i < tokens.length && tokens[i].kind == "CSS_COLON") i++
                let value = ""
                if (i < tokens.length && tokens[i].kind == "CSS_VALUE") {
                    value = tokens[i].text
                    i++
                }
                if (i < tokens.length && tokens[i].kind == "CSS_SEMI") i++

                const scanResult = scanCSSValueForReactiveRefs(value)
                const rule = { prop, value, span: startSpan }
                if (scanResult.refs.length > 0) {
                    rule.reactiveRefs = scanResult.refs
                    rule.isExpression = scanResult.isExpression
                }
                rules.push(rule)
            } else if (tok.kind == "CSS_SELECTOR") {
                const selector = tok.text
                const selectorSpan = tokenSpan(tok, filePath)
                i++
                if (i < tokens.length && tokens[i].kind == "CSS_LBRACE") {
                    i++
                    const declarations = []
                    while (i < tokens.length && tokens[i].kind != "CSS_RBRACE" && tokens[i].kind != "EOF") {
                        if (tokens[i].kind == "CSS_PROP") {
                            const prop = tokens[i].text
                            const propSpan = tokenSpan(tokens[i], filePath)
                            i++
                            if (i < tokens.length && tokens[i].kind == "CSS_COLON") i++
                            let value = ""
                            if (i < tokens.length && tokens[i].kind == "CSS_VALUE") {
                                value = tokens[i].text
                                i++
                            }
                            if (i < tokens.length && tokens[i].kind == "CSS_SEMI") i++
                            const scanResult = scanCSSValueForReactiveRefs(value)
                            const decl = { prop, value, span: propSpan }
                            if (scanResult.refs.length > 0) { decl.reactiveRefs = scanResult.refs; decl.isExpression = scanResult.isExpression }
                            declarations.push(decl)
                        } else {
                            i++
                        }
                    }
                    if (i < tokens.length && tokens[i].kind == "CSS_RBRACE") i++
                    rules.push({ selector, declarations, span: selectorSpan })
                } else {
                    rules.push({ selector, span: selectorSpan })
                }
            } else {
                i++
            }
        }

        return rules
    }

    // ---------------------------------------------------------------------------
    // Test block parser (~{})
    // ---------------------------------------------------------------------------

    fn parseTestBody(tokens, filePath, span, errors) {
        let i = 0
        let groupName = null
        const tests = []
        let beforeStmts = null
        let afterStmts = null

        const OPEN_BRACE = String.fromCharCode(123)
        const CLOSE_BRACE = String.fromCharCode(125)

        function collectBody() {
            const stmts = []
            let depth = 0
            let parts = []

            while (i < tokens.length && tokens[i].kind != "EOF") {
                const tok = tokens[i]
                if (tok.kind == "PUNCT" && tok.text == OPEN_BRACE) {
                    depth++
                    parts.push(tok.text)
                    i++
                } else if (tok.kind == "PUNCT" && tok.text == CLOSE_BRACE) {
                    if (depth == 0) break
                    depth--
                    parts.push(tok.text)
                    i++
                    if (depth == 0 && parts.length > 0) {
                        stmts.push(parts.join(" ").trim())
                        parts = []
                    }
                } else {
                    parts.push(tok.text)
                    i++
                }
            }
            if (parts.length > 0) {
                const s = parts.join(" ").trim()
                if (s) stmts.push(s)
            }
            return stmts
        }

        function parseAssertExpr(raw) {
            const ops = ["==", "!=", ">=", "<=", ">", "<"]
            for (const op of ops) {
                const idx = raw.indexOf(op)
                if (idx != -1) {
                    const lhs = raw.slice(0, idx).trim()
                    const rhs = raw.slice(idx + op.length).trim()
                    if (lhs && rhs) {
                        return { raw, op, lhs, rhs }
                    }
                }
            }
            return { raw, op: null, lhs: null, rhs: null }
        }

        function collectAssertTokens() {
            const parts = []
            let depth = 0
            while (i < tokens.length && tokens[i].kind != "EOF") {
                const tok = tokens[i]
                if (tok.kind == "PUNCT" && tok.text == CLOSE_BRACE && depth == 0) break
                if (depth == 0 && tok.kind == "IDENT" &&
                    (tok.text == "assert" || tok.text == "test" ||
                     tok.text == "before" || tok.text == "after")) break
                if (tok.kind == "PUNCT" && tok.text == OPEN_BRACE) depth++
                else if (tok.kind == "PUNCT" && tok.text == CLOSE_BRACE) depth--
                parts.push(tok.text)
                i++
            }
            return parts.join(" ").trim()
        }

        // Main parse loop
        while (i < tokens.length && tokens[i].kind != "EOF") {
            const tok = tokens[i]

            if (tok.kind == "STRING" && groupName == null && tests.length == 0 && beforeStmts == null) {
                groupName = tok.text
                i++
                continue
            }

            if (tok.kind == "IDENT" && tok.text == "before") {
                i++
                if (i < tokens.length && tokens[i].kind == "PUNCT" && tokens[i].text == OPEN_BRACE) i++
                beforeStmts = collectBody()
                if (i < tokens.length && tokens[i].kind == "PUNCT" && tokens[i].text == CLOSE_BRACE) i++
                continue
            }

            if (tok.kind == "IDENT" && tok.text == "after") {
                i++
                if (i < tokens.length && tokens[i].kind == "PUNCT" && tokens[i].text == OPEN_BRACE) i++
                afterStmts = collectBody()
                if (i < tokens.length && tokens[i].kind == "PUNCT" && tokens[i].text == CLOSE_BRACE) i++
                continue
            }

            if (tok.kind == "IDENT" && tok.text == "test") {
                const testLine = (tok.span && tok.span.line) ? tok.span.line : span.line
                i++

                let testName = ""
                if (i < tokens.length && tokens[i].kind == "STRING") {
                    testName = tokens[i].text
                    i++
                }

                if (i < tokens.length && tokens[i].kind == "PUNCT" && tokens[i].text == OPEN_BRACE) i++

                const caseBody = []
                const caseAsserts = []

                while (i < tokens.length && tokens[i].kind != "EOF") {
                    const inner = tokens[i]
                    if (inner.kind == "PUNCT" && inner.text == CLOSE_BRACE) break

                    if (inner.kind == "IDENT" && inner.text == "assert") {
                        i++
                        const rawExpr = collectAssertTokens()
                        const assertNode = parseAssertExpr(rawExpr)
                        caseAsserts.push(assertNode)
                        caseBody.push("assert " + rawExpr)
                    } else {
                        const stmtParts = []
                        let depth = 0
                        while (i < tokens.length && tokens[i].kind != "EOF") {
                            const t = tokens[i]
                            if (t.kind == "PUNCT" && t.text == CLOSE_BRACE && depth == 0) break
                            if (depth == 0 && t.kind == "IDENT" && t.text == "assert") break
                            if (t.kind == "PUNCT" && t.text == OPEN_BRACE) depth++
                            else if (t.kind == "PUNCT" && t.text == CLOSE_BRACE) depth--
                            stmtParts.push(t.text)
                            i++
                        }
                        const stmt = stmtParts.join(" ").trim()
                        if (stmt) caseBody.push(stmt)
                    }
                }

                if (i < tokens.length && tokens[i].kind == "PUNCT" && tokens[i].text == CLOSE_BRACE) i++

                tests.push({
                    name: testName,
                    line: testLine,
                    body: caseBody,
                    asserts: caseAsserts,
                })
                continue
            }

            // Top-level assert
            if (tok.kind == "IDENT" && tok.text == "assert") {
                i++
                const rawExpr = collectAssertTokens()
                const assertNode = parseAssertExpr(rawExpr)

                if (tests.length == 0 || tests[tests.length - 1].name != "") {
                    tests.push({
                        name: "",
                        line: (tok.span && tok.span.line) ? tok.span.line : span.line,
                        body: [],
                        asserts: [],
                    })
                }
                const implicit = tests[tests.length - 1]
                implicit.asserts.push(assertNode)
                implicit.body.push("assert " + rawExpr)
                continue
            }

            i++
        }

        return {
            name: groupName,
            line: span.line,
            tests,
            before: beforeStmts,
            after: afterStmts,
        }
    }

    // ---------------------------------------------------------------------------
    // Error effect block parser
    // ---------------------------------------------------------------------------

    fn parseErrorTokens(tokens, filePath) {
        const arms = []
        let i = 0

        while (i < tokens.length && tokens[i].kind != "EOF") {
            const tok = tokens[i]

            if (tok.kind == "PUNCT" && tok.text == "|") {
                const armStart = tok
                i++

                let pattern = "_"
                let binding = ""

                if (i < tokens.length && tokens[i].kind == "OPERATOR" && tokens[i].text == "::") {
                    i++
                    if (i < tokens.length && (tokens[i].kind == "IDENT" || tokens[i].kind == "KEYWORD")) {
                        pattern = "::" + tokens[i].text
                        i++
                    }
                } else if (i < tokens.length && tokens[i].text == "_") {
                    pattern = "_"
                    i++
                }

                if (i < tokens.length && (tokens[i].kind == "IDENT")) {
                    binding = tokens[i].text
                    i++
                }

                if (i < tokens.length && tokens[i].kind == "OPERATOR" && tokens[i].text == "=>") {
                    i++
                } else if (i < tokens.length && tokens[i].kind == "PUNCT" && tokens[i].text == "-") {
                    i++
                    if (i < tokens.length && tokens[i].kind == "OPERATOR" && tokens[i].text == ">") i++
                    if (i < tokens.length && tokens[i].kind == "PUNCT" && tokens[i].text == ">") i++
                }

                const handlerParts = []
                while (i < tokens.length && tokens[i].kind != "EOF") {
                    if (tokens[i].kind == "PUNCT" && tokens[i].text == "|") break
                    if (
                        i + 1 < tokens.length &&
                        (tokens[i].kind == "IDENT" || tokens[i].kind == "KEYWORD") &&
                        tokens[i + 1].kind == "OPERATOR" &&
                        tokens[i + 1].text == "=>" &&
                        (tokens[i].text == "_" || /^[A-Z]/.test(tokens[i].text))
                    ) break
                    if (tokens[i].kind == "STRING") {
                        handlerParts.push('"' + tokens[i].text.replace(/\\/g, '\\\\').replace(/"/g, '\\"') + '"')
                    } else {
                        handlerParts.push(tokens[i].text)
                    }
                    i++
                }

                arms.push({
                    pattern,
                    binding,
                    handler: handlerParts.join(" ").trim(),
                    span: tokenSpan(armStart, filePath),
                })
            } else if (
                i + 1 < tokens.length &&
                (tok.kind == "IDENT" || tok.kind == "KEYWORD") &&
                tokens[i + 1].kind == "OPERATOR" &&
                tokens[i + 1].text == "=>" &&
                (tok.text == "_" || /^[A-Z]/.test(tok.text))
            ) {
                const armStart = tok
                const typeName = tok.text
                const pattern = typeName == "_" ? "_" : "::" + typeName
                const binding = "e"
                i++
                i++
                const handlerParts = []
                while (i < tokens.length && tokens[i].kind != "EOF") {
                    if (
                        i + 1 < tokens.length &&
                        (tokens[i].kind == "IDENT" || tokens[i].kind == "KEYWORD") &&
                        tokens[i + 1].kind == "OPERATOR" &&
                        tokens[i + 1].text == "=>" &&
                        (tokens[i].text == "_" || /^[A-Z]/.test(tokens[i].text))
                    ) break
                    if (tokens[i].kind == "PUNCT" && tokens[i].text == "|") break
                    if (tokens[i].kind == "STRING") {
                        handlerParts.push('"' + tokens[i].text.replace(/\\/g, '\\\\').replace(/"/g, '\\"') + '"')
                    } else {
                        handlerParts.push(tokens[i].text)
                    }
                    i++
                }
                arms.push({
                    pattern,
                    binding,
                    handler: handlerParts.join(" ").trim(),
                    span: tokenSpan(armStart, filePath),
                })
            } else {
                i++
            }
        }

        return arms
    }

    // ---------------------------------------------------------------------------
    // Core block -> ASTNode builder
    // ---------------------------------------------------------------------------

    function buildBlock(block, filePath, parentContextKind, counter, errors) {
        const OPEN_BRACE = String.fromCharCode(123)
        const CLOSE_BRACE = String.fromCharCode(125)
        const span = fullSpan(block.span, filePath)

        if (block.type == "text") {
            return {
                id: ++counter.next,
                kind: "text",
                value: block.raw,
                span,
            }
        }

        if (block.type == "comment") {
            return {
                id: ++counter.next,
                kind: "comment",
                value: block.raw,
                span,
            }
        }

        if (block.type == "markup") {
            const attrTokens = tokenizeAttributes(
                block.raw,
                block.span.start,
                block.span.line,
                block.span.col,
                "markup"
            )
            const attrs = parseAttributes(attrTokens, filePath, errors, block.isComponent == true)

            const children = block.children.map(function(child) {
                return buildBlock(child, filePath, "markup", counter, errors)
            }).filter(Boolean)

            return {
                id: ++counter.next,
                kind: "markup",
                tag: block.name,
                attrs,
                children,
                selfClosing: block.closerForm == "self-closing",
                closerForm: block.closerForm,
                isComponent: block.isComponent == true,
                span,
            }
        }

        if (block.type == "state") {
            const attrTokens = tokenizeAttributes(
                block.raw,
                block.span.start,
                block.span.line,
                block.span.col,
                "state"
            )

            const typedResult = parseTypedAttributes(attrTokens, filePath, errors)

            const children = block.children.map(function(child) {
                return buildBlock(child, filePath, "state", counter, errors)
            }).filter(Boolean)

            if (typedResult.hasTypedDecls) {
                tagFunctionsWithStateType(children, block.name)

                return {
                    id: ++counter.next,
                    kind: "state-constructor-def",
                    stateType: block.name,
                    typedAttrs: typedResult.typedAttrs,
                    attrs: typedResult.attrs,
                    children,
                    span,
                }
            }

            return {
                id: ++counter.next,
                kind: "state",
                stateType: block.name,
                attrs: typedResult.attrs,
                children,
                span,
            }
        }

        if (block.type == "logic") {
            const bodyRaw = block.raw.slice(2, block.raw.length - 1)
            const bodyOffset = block.span.start + 2
            const bodyLine = block.span.line
            const bodyCol = block.span.col + 2

            const tokens = tokenizeLogic(bodyRaw, bodyOffset, bodyLine, bodyCol, block.children)
            const body = parseLogicBody(tokens, filePath, block.children, block, counter, errors, "logic")

            const imports = body.filter(function(n) { return n.kind == "import-decl" })
            const exports = body.filter(function(n) { return n.kind == "export-decl" })
            const typeDecls = body.filter(function(n) { return n.kind == "type-decl" })
            const components = []
            const consumedIndices = new Set()
            for (let ci = 0; ci < body.length; ci++) {
                if (body[ci].kind == "component-def") {
                    const defChildren = []
                    for (let si = ci + 1; si < body.length; si++) {
                        if (body[si].kind == "component-def" || body[si].kind == "import-decl" ||
                            body[si].kind == "export-decl" || body[si].kind == "type-decl") break
                        defChildren.push(body[si])
                        consumedIndices.add(si)
                    }
                    body[ci].defChildren = defChildren
                    components.push(body[ci])
                }
            }
            const filteredBody = consumedIndices.size > 0
                ? body.filter(function(_, idx) { return !consumedIndices.has(idx) })
                : body

            return {
                id: ++counter.next,
                kind: "logic",
                body: filteredBody,
                imports,
                exports,
                typeDecls,
                components,
                span,
            }
        }

        if (block.type == "sql") {
            const bodyRaw = block.raw.slice(2, block.raw.length - 1)
            const bodyOffset = block.span.start + 2
            const bodyLine = block.span.line
            const bodyCol = block.span.col + 2

            const tokens = tokenizeSQL(bodyRaw, bodyOffset, bodyLine, bodyCol)
            const sqlResult = parseSQLTokens(tokens, filePath)

            return {
                id: ++counter.next,
                kind: "sql",
                query: sqlResult.query,
                chainedCalls: sqlResult.chainedCalls,
                span,
            }
        }

        if (block.type == "css") {
            const bodyRaw = block.raw.slice(2, block.raw.length - 1)
            const bodyOffset = block.span.start + 2
            const bodyLine = block.span.line
            const bodyCol = block.span.col + 2

            const tokens = tokenizeCSS(bodyRaw, bodyOffset, bodyLine, bodyCol)
            const rules = parseCSSTokens(tokens, filePath)

            return {
                id: ++counter.next,
                kind: "css-inline",
                rules,
                span,
            }
        }

        if (block.type == "style") {
            const children = block.children.map(function(child) {
                return buildBlock(child, filePath, "style", counter, errors)
            }).filter(Boolean)

            return {
                id: ++counter.next,
                kind: "style",
                rules: [],
                children,
                span,
            }
        }

        if (block.type == "error-effect") {
            const rawContent = block.raw.slice(2)
            const arms = []

            const firstClose = rawContent.indexOf(CLOSE_BRACE)
            const hasCatch = firstClose != -1 &&
                new RegExp(CLOSE_BRACE + "\\s*catch\\b").test(rawContent.slice(firstClose))

            if (hasCatch) {
                const tryBodyRaw = rawContent.slice(0, firstClose)
                let rest = rawContent.slice(firstClose + 1).trim()

                const catchPattern = new RegExp("^catch\\s+([A-Za-z_$][A-Za-z0-9_$]*)(?:\\s+as\\s+([A-Za-z_$][A-Za-z0-9_$]*))?\\s*" + String.fromCharCode(123))
                while (rest.length > 0) {
                    const m = rest.match(catchPattern)
                    if (!m) break
                    const typeName = m[1]
                    const binding = m[2] != null ? m[2] : ""
                    const openPos = rest.indexOf(OPEN_BRACE, m.index != null ? m.index : 0)
                    let depth = 0
                    let closePos = openPos
                    for (let ci = openPos; ci < rest.length; ci++) {
                        if (rest[ci] == OPEN_BRACE) depth++
                        else if (rest[ci] == CLOSE_BRACE) { depth--; if (depth == 0) { closePos = ci; break } }
                    }
                    const handlerBody = rest.slice(openPos + 1, closePos).trim()
                    arms.push({
                        pattern: typeName,
                        binding,
                        handler: handlerBody,
                        span: { file: filePath, start: block.span.start, end: block.span.end, line: block.span.line, col: block.span.col },
                    })
                    rest = rest.slice(closePos + 1).trim()
                }

                const bodyOffset = block.span.start + 2
                const tryTokens = tokenizeLogic(tryBodyRaw, bodyOffset, block.span.line, block.span.col + 2, [])
                const tryBody = parseLogicBody(tryTokens, filePath, [], block, counter, errors, "logic")

                return {
                    id: ++counter.next,
                    kind: "error-effect",
                    body: tryBody,
                    arms,
                    span,
                }
            } else {
                const bodyRaw = rawContent.slice(0, rawContent.length - 1)
                const bodyOffset = block.span.start + 2
                const tokens = tokenizeError(bodyRaw, bodyOffset, block.span.line, block.span.col + 2)
                const legacyArms = parseErrorTokens(tokens, filePath)
                return {
                    id: ++counter.next,
                    kind: "error-effect",
                    arms: legacyArms,
                    span,
                }
            }
        }

        if (block.type == "meta") {
            const bodyRaw = block.raw.slice(2, block.raw.length - 1)
            const bodyOffset = block.span.start + 2
            const bodyLine = block.span.line
            const bodyCol = block.span.col + 2

            const tokens = tokenizeLogic(bodyRaw, bodyOffset, bodyLine, bodyCol, block.children)
            const body = parseLogicBody(tokens, filePath, block.children, block, counter, errors, "meta")

            const parentContext = parentContextKind
                ? mapParentContext(parentContextKind)
                : "markup"

            return {
                id: ++counter.next,
                kind: "meta",
                body,
                parentContext,
                span,
            }
        }

        if (block.type == "test") {
            const bodyRaw = block.raw.slice(2, block.raw.length - 1)
            const bodyOffset = block.span.start + 2
            const bodyLine = block.span.line
            const bodyCol = block.span.col + 2

            const tokens = tokenizeLogic(bodyRaw, bodyOffset, bodyLine, bodyCol, block.children)
            const testGroup = parseTestBody(tokens, filePath, span, errors)

            return {
                id: ++counter.next,
                kind: "test",
                testGroup,
                span,
            }
        }

        // default: unrecognized block
        errors.push(new TABError(
            "E-PARSE-001",
            "E-PARSE-001: The construct starting here is not a recognized scrml block. " +
            "Valid blocks are: markup tags, `< state>` blocks, `$" + String.fromCharCode(123) + " " + String.fromCharCode(125) + "` logic, `?" + String.fromCharCode(123) + " " + String.fromCharCode(125) + "` SQL, `#" + String.fromCharCode(123) + " " + String.fromCharCode(125) + "` inline CSS, " +
            "`<style>`, `!" + String.fromCharCode(123) + " " + String.fromCharCode(125) + "` error handlers, `^" + String.fromCharCode(123) + " " + String.fromCharCode(125) + "` meta, and `~" + String.fromCharCode(123) + " " + String.fromCharCode(125) + "` test contexts. " +
            "If you intended one of these, check that the opening delimiter is spelled correctly.",
            span,
        ))
        return null
    }

    // ---------------------------------------------------------------------------
    // mapParentContext
    // ---------------------------------------------------------------------------

    fn mapParentContext(blockType) {
        if (blockType == "markup") return "markup"
        if (blockType == "state") return "state"
        if (blockType == "logic") return "logic"
        if (blockType == "sql") return "sql"
        if (blockType == "css") return "css"
        if (blockType == "error-effect") return "error"
        if (blockType == "meta") return "meta"
        return "markup"
    }

    // ---------------------------------------------------------------------------
    // If-chain collapsing
    // ---------------------------------------------------------------------------

    fn isWhitespaceText(node) {
        return node.kind == "text" && (!node.value || !node.value.trim())
    }

    fn getAttr(node, name) {
        if (node.kind != "markup") return null
        const attrs = node.attrs != null ? node.attrs : []
        return attrs.find(function(a) { return a.name == name }) != null ? attrs.find(function(a) { return a.name == name }) : null
    }

    fn hasAttr(node) {
        const names = Array.prototype.slice.call(arguments, 1)
        return names.some(function(n) { return getAttr(node, n) != null })
    }

    fn collapseIfChains(nodes, errors, filePath) {
        for (const node of nodes) {
            if (node.children && Array.isArray(node.children)) {
                node.children = collapseIfChains(node.children, errors, filePath)
            }
            if (node.body && Array.isArray(node.body)) {
                node.body = collapseIfChains(node.body, errors, filePath)
            }
        }

        const result = []
        let idx = 0

        while (idx < nodes.length) {
            const node = nodes[idx]

            // E-CTRL-005
            if (node.kind == "markup" && hasAttr(node, "if") && (hasAttr(node, "else") || hasAttr(node, "else-if"))) {
                const span = node.span != null ? node.span : { line: 0, col: 0 }
                errors.push(new TABError(
                    "E-CTRL-005",
                    "E-CTRL-005: `else` or `else-if=` and `if=` cannot appear on the same element.",
                    span,
                ))
                result.push(node)
                idx++
                continue
            }

            // E-CTRL-001/002
            if (node.kind == "markup" && !hasAttr(node, "if")) {
                if (hasAttr(node, "else")) {
                    const span = node.span != null ? node.span : { line: 0, col: 0 }
                    errors.push(new TABError(
                        "E-CTRL-001",
                        "E-CTRL-001: `else` on line " + span.line + " has no preceding `if=` element at the same level.",
                        span,
                    ))
                    result.push(node)
                    idx++
                    continue
                }
                if (hasAttr(node, "else-if")) {
                    const span = node.span != null ? node.span : { line: 0, col: 0 }
                    errors.push(new TABError(
                        "E-CTRL-002",
                        "E-CTRL-002: `else-if=` on line " + span.line + " has no preceding `if=` element at the same level.",
                        span,
                    ))
                    result.push(node)
                    idx++
                    continue
                }
            }

            if (node.kind != "markup" || !hasAttr(node, "if")) {
                result.push(node)
                idx++
                continue
            }

            // Found if= — start building chain
            const ifAttr = getAttr(node, "if")
            const branches = [{ condition: ifAttr.value, element: node }]
            let elseBranch = null
            let j = idx + 1

            while (j < nodes.length) {
                if (isWhitespaceText(nodes[j])) {
                    j++
                    continue
                }

                const sibling = nodes[j]
                if (sibling.kind != "markup") break

                if ((sibling.kind == "state" || sibling.kind == "state-constructor-def") &&
                    (hasAttr(sibling, "else") || hasAttr(sibling, "else-if"))) {
                    errors.push(new TABError(
                        "E-CTRL-004",
                        "E-CTRL-004: `else` or `else-if=` cannot appear on a state object opener.",
                        sibling.span != null ? sibling.span : { line: 0, col: 0 },
                    ))
                    break
                }

                if (hasAttr(sibling, "else-if")) {
                    if (elseBranch) {
                        errors.push(new TABError(
                            "E-CTRL-003",
                            "E-CTRL-003: The element on line " + ((sibling.span && sibling.span.line) ? sibling.span.line : 0) + " tries to extend a chain that already ended with `else`.",
                            sibling.span != null ? sibling.span : { line: 0, col: 0 },
                        ))
                        break
                    }
                    const elseIfAttr = getAttr(sibling, "else-if")
                    branches.push({ condition: elseIfAttr.value, element: sibling })
                    j++
                    continue
                }

                if (hasAttr(sibling, "else")) {
                    if (elseBranch) {
                        errors.push(new TABError(
                            "E-CTRL-003",
                            "E-CTRL-003: The element on line " + ((sibling.span && sibling.span.line) ? sibling.span.line : 0) + " tries to extend a chain that already ended with `else`.",
                            sibling.span != null ? sibling.span : { line: 0, col: 0 },
                        ))
                        break
                    }
                    elseBranch = sibling
                    j++
                    continue
                }

                break
            }

            if (branches.length == 1 && !elseBranch) {
                result.push(node)
                idx++
                continue
            }

            result.push({
                id: node.id,
                kind: "if-chain",
                branches,
                elseBranch,
                span: node.span,
            })

            idx = j
        }

        return result
    }

    // ---------------------------------------------------------------------------
    // Hoist collector
    // ---------------------------------------------------------------------------

    fn collectHoisted(nodes) {
        const imports = []
        const exports = []
        const typeDecls = []
        const components = []

        function walk(nodeList) {
            for (const node of nodeList) {
                if (!node) continue
                if (node.kind == "logic") {
                    imports.push.apply(imports, (node.imports || []))
                    exports.push.apply(exports, (node.exports || []))
                    typeDecls.push.apply(typeDecls, (node.typeDecls || []))
                    components.push.apply(components, (node.components || []))
                }
                if (node.kind == "markup" || node.kind == "state") {
                    walk(node.children || [])
                }
                if (node.kind == "meta") {
                    walkBodyNodes(node.body || [])
                }
            }
        }

        function walkBodyNodes(bodyNodes) {
            for (const node of bodyNodes) {
                if (!node) continue
                if (node.kind == "import-decl") imports.push(node)
                if (node.kind == "export-decl") exports.push(node)
                if (node.kind == "type-decl") typeDecls.push(node)
                if (node.kind == "component-def") components.push(node)
                if (node.kind == "function-decl" && node.body) walkBodyNodes(node.body)
            }
        }

        walk(nodes)
        return { imports, exports, typeDecls, components }
    }

    // ---------------------------------------------------------------------------
    // Span table builder
    // ---------------------------------------------------------------------------

    fn buildSpanTable(nodes) {
        const table = new Map()

        function assign(node) {
            if (!node || typeof node != "object") return
            if (node.id != undefined && node.span) table.set(node.id, node.span)

            for (const key of Object.keys(node)) {
                if (key == "span" || key == "id") continue
                const val = node[key]
                if (Array.isArray(val)) val.forEach(assign)
                else if (val && typeof val == "object" && val.kind) assign(val)
            }
        }

        nodes.forEach(assign)
        return table
    }

    // ---------------------------------------------------------------------------
    // Public entry point
    // ---------------------------------------------------------------------------

    export function buildAST(bsOutput) {
        const filePath = bsOutput.filePath
        const blocks = bsOutput.blocks

        const counter = { next: 0 }
        const errors = []

        let nodes = blocks.map(function(block) { return buildBlock(block, filePath, null, counter, errors) }).filter(Boolean)

        nodes = collapseIfChains(nodes, errors, filePath)

        const hoisted = collectHoisted(nodes)

        const spanTable = buildSpanTable(nodes)

        const spans = {}
        for (const entry of spanTable) {
            spans[entry[0]] = entry[1]
        }

        const hasProgramRoot = nodes.some(
            function(n) { return n.kind == "markup" && n.tag == "program" }
        )

        let authConfig = null
        const programNode = nodes.find(function(n) { return n.kind == "markup" && n.tag == "program" })
        if (programNode) {
            const programAttrs = programNode.attrs != null ? programNode.attrs : []

            const getAttrValue = function(name) {
                const a = programAttrs.find(function(attr) { return attr.name == name })
                if (!a || !a.value || a.value.kind == "absent") return null
                if (a.value.kind == "string-literal") return a.value.value
                return null
            }

            const authVal = getAttrValue("auth")
            if (authVal) {
                const loginRedirect = getAttrValue("loginRedirect") != null ? getAttrValue("loginRedirect") : "/login"
                const csrf = getAttrValue("csrf") != null ? getAttrValue("csrf") : "off"
                const sessionExpiry = getAttrValue("sessionExpiry") != null ? getAttrValue("sessionExpiry") : "1h"

                authConfig = {
                    auth: authVal,
                    loginRedirect,
                    csrf,
                    sessionExpiry,
                }

                programNode.auth = authVal
                programNode.loginRedirect = loginRedirect
                programNode.csrf = csrf
                programNode.sessionExpiry = sessionExpiry
            }
        }

        let middlewareConfig = null
        if (programNode) {
            const programAttrs2 = programNode.attrs != null ? programNode.attrs : []

            const getMWAttr = function(attrName) {
                const a = programAttrs2.find(function(attr) { return attr.name == attrName })
                if (!a || !a.value || a.value.kind == "absent") return null
                if (a.value.kind == "string-literal") return a.value.value
                return null
            }

            const mwCors = getMWAttr("cors")
            const mwLog = getMWAttr("log")
            const mwCsrf = getMWAttr("csrf")
            const mwRatelimit = getMWAttr("ratelimit")
            const mwHeaders = getMWAttr("headers")

            if (mwCors != null || mwLog != null || mwCsrf != null || mwRatelimit != null || mwHeaders != null) {
                middlewareConfig = { cors: mwCors, log: mwLog, csrf: mwCsrf, ratelimit: mwRatelimit, headers: mwHeaders }
            }

            if (mwCsrf == "on" && !authConfig) {
                const programSpan2 = programNode.span != null ? programNode.span : { file: filePath, start: 0, end: 0, line: 1, col: 1 }
                errors.push(new TABError(
                    "E-MW-001",
                    'E-MW-001: csrf="on" requires session infrastructure. ' +
                    'Add <program auth="required"> or use a session handler, or remove csrf="on".',
                    programSpan2,
                ))
            }

            if (mwRatelimit != null && !/^\d+\/(sec|min|hour)$/.test(mwRatelimit)) {
                const ratelimitAttr = programAttrs2.find(function(attr) { return attr.name == "ratelimit" })
                const ratelimitSpan = ratelimitAttr && ratelimitAttr.span ? ratelimitAttr.span : { file: filePath, start: 0, end: 0, line: 1, col: 1 }
                errors.push(new TABError(
                    "E-MW-002",
                    'E-MW-002: Invalid ratelimit= value "' + mwRatelimit + '". Expected format: N/unit where unit is sec, min, or hour. Example: ratelimit="100/min".',
                    ratelimitSpan,
                ))
            }
        }

        // E-MW-005/E-MW-006: handle() validation
        {
            const nodeListsToSearch = [nodes]
            if (programNode && Array.isArray(programNode.children)) {
                nodeListsToSearch.push(programNode.children)
            }

            const topLevelHandles = []
            for (const nodeList of nodeListsToSearch) {
                for (const node of nodeList) {
                    if (node && node.kind == "logic") {
                        for (const stmt of (node.body != null ? node.body : [])) {
                            if (stmt && stmt.kind == "function-decl" && stmt.isHandleEscapeHatch) {
                                topLevelHandles.push(stmt)
                            }
                        }
                    }
                }
            }

            if (topLevelHandles.length > 1) {
                const firstSpan = topLevelHandles[0].span
                const firstLine = firstSpan ? firstSpan.line : "?"
                for (let idx = 1; idx < topLevelHandles.length; idx++) {
                    errors.push(new TABError(
                        "E-MW-005",
                        "E-MW-005: Only one handle() function is allowed per file. A second definition was found here; the first is at line " + firstLine + ".",
                        topLevelHandles[idx].span != null ? topLevelHandles[idx].span : { file: filePath, start: 0, end: 0, line: 1, col: 1 },
                    ))
                }
            }

            function findNestedHandles(stmts) {
                for (const stmt of (stmts != null ? stmts : [])) {
                    if (!stmt) continue
                    if (stmt.kind == "function-decl" && stmt.isHandleEscapeHatch) {
                        errors.push(new TABError(
                            "E-MW-006",
                            "E-MW-006: handle() must be defined at file top level inside a $" + String.fromCharCode(123) + " " + String.fromCharCode(125) + " block. Found definition inside a nested function body.",
                            stmt.span != null ? stmt.span : { file: filePath, start: 0, end: 0, line: 1, col: 1 },
                        ))
                    }
                    if (stmt.kind == "function-decl" && !stmt.isHandleEscapeHatch) {
                        findNestedHandles(stmt.body != null ? stmt.body : [])
                    }
                    if (stmt.kind == "if-stmt") {
                        findNestedHandles(stmt.consequent != null ? stmt.consequent : [])
                        findNestedHandles(stmt.alternate != null ? stmt.alternate : [])
                    }
                    if (stmt.kind == "for-stmt" || stmt.kind == "while-stmt") {
                        findNestedHandles(stmt.body != null ? stmt.body : [])
                    }
                }
            }

            for (const nodeList of nodeListsToSearch) {
                for (const node of nodeList) {
                    if (node && node.kind == "logic") {
                        for (const stmt of (node.body != null ? node.body : [])) {
                            if (stmt && stmt.kind == "function-decl" && !stmt.isHandleEscapeHatch) {
                                findNestedHandles(stmt.body != null ? stmt.body : [])
                            }
                        }
                    }
                }
            }
        }

        const ast = {
            filePath,
            nodes,
            imports: hoisted.imports,
            exports: hoisted.exports,
            components: hoisted.components,
            typeDecls: hoisted.typeDecls,
            spans,
            hasProgramRoot,
            authConfig,
            middlewareConfig,
        }

        if (!hasProgramRoot) {
            errors.push(new TABError(
                "W-PROGRAM-001",
                "W-PROGRAM-001: No <program> root element found. Consider wrapping your file " +
                "content in <program> ... </program> for explicit configuration of database " +
                "connections, protection, and HTML spec version.",
                { start: 0, end: 0, line: 1, col: 1 },
            ))
            errors[errors.length - 1].severity = "warning"
        }

        return { filePath, ast, errors }
    }

    // ---------------------------------------------------------------------------
    // Pipeline contract wrapper
    // ---------------------------------------------------------------------------

    export function runTAB(input) {
        return buildAST(input)
    }

    export { TABError as default }
}
</program>
