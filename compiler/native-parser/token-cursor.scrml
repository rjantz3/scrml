// token-cursor.scrml — token-stream cursor over M1's Token[] (DD §D4 P5).
//
// The parser-layer analog of M1's character-stream cursor.scrml. M1's
// cursor walks source BYTES; this cursor walks the TOKEN ARRAY that
// `lex(source)` (lex.scrml) produces. The expression parser (parse-expr.scrml)
// consumes tokens through this cursor.
//
// PILLAR 5b classification (DD §D1):
//   The cursor's POSITION (`idx`) is STATE — its lifecycle is the entire
//   parse run, it has identity ("which token are we at?"), it transitions
//   on every advance. Per DD §D4 P5 the canonical form is a V5-strict
//   reactive cell over `{tokens: Token[], idx: int}` — engine-shape is NOT
//   required (single "advancing" condition, no transition contract beyond
//   `idx++`; identical classification to M1's character cursor).
//
//   The cursor's READS (peek, peekKind, current) are CALCULATION — pure
//   functions over (tokens, idx + k); no condition-dependent dispatch.
//   Per DD §D1 worked example "tokens-at-offset is calculation."
//
//   The SNAPSHOT / RESTORE pair (DD §D4 P3 bounded-lookahead-with-commit)
//   is the parser's speculation primitive. Per OQ3 the bounded JS subset
//   needs lookahead-with-commit, NOT general backtracking; snapshot/restore
//   over `idx` is that primitive. In canonical scrml the snapshot is
//   `lin`-typed (§35 exactly-once consumption — the restore CONSUMES the
//   snapshot, designing out double-restore). The live surface returns a
//   plain {idx} object; the lin-typing lands at the M5 swap-in.
//
// V5-STRICT NOTE: in a fully-scrml-source build the cursor would be:
//
//   <tokenCursor> = { tokens: [], idx: 0 }              // declare
//   @tokenCursor.idx = @tokenCursor.idx + 1             // advance (write)
//   @tokenCursor.tokens[@tokenCursor.idx]               // current (read)
//
// LIVE M2.1 SURFACE (JS-host): a plain object passed by reference, with
// pure-fn read helpers — the SAME M5-swap concession as cursor.scrml's
// `.pos`-mutation (the README ANOMALY-2 .scrml<->.js shadow). Tests import
// the .js shadow.

${
    import { TokenKind } from "./token.scrml"

    // makeTokenCursor — construct a cursor over a Token[] (the array
    // `lex(source)` returns). Calculation: pure fn from input → starting
    // cursor state. The token array is assumed to END with an EOF token
    // (lex.scrml guarantees this); the cursor never advances past it.
    export fn makeTokenCursor(tokens) {
        return {
            tokens,            // immutable token buffer (lex output)
            idx:    0,         // current token index (advances; the STATE field)
        }
    }

    // tokenCount — calculation (read): how many tokens in the buffer.
    export fn tokenCount(cursor) {
        return cursor.tokens.length
    }

    // atEnd — calculation (predicate): are we at (or past) the EOF token?
    // The EOF token is the LAST element; "at end" means the current token
    // IS the EOF token (or, defensively, the index ran past the array).
    export fn atEnd(cursor) {
        if (cursor.idx >= cursor.tokens.length) {
            return true
        }
        return cursor.tokens[cursor.idx].kind == TokenKind.EOF
    }

    // peek — calculation (read): the token at `idx + k` (k defaults 0).
    // Past-end reads return the EOF token (the last element) so callers
    // can always inspect a `.kind` without a null-guard — mirrors M1's
    // cursor.peekChar returning "" past EOF.
    export fn peek(cursor, k) {
        const offset = cursor.idx + (k ?? 0)
        if (offset >= cursor.tokens.length) {
            if (cursor.tokens.length == 0) {
                return not
            }
            return cursor.tokens[cursor.tokens.length - 1]
        }
        if (offset < 0) {
            return cursor.tokens[0]
        }
        return cursor.tokens[offset]
    }

    // current — calculation (read): the token at the cursor (peek 0).
    export fn current(cursor) {
        return peek(cursor, 0)
    }

    // peekKind — calculation (read): the `.kind` of the token at `idx + k`.
    // Returns the EOF kind past-end (since peek returns the EOF token).
    export fn peekKind(cursor, k) {
        const tok = peek(cursor, k)
        if (tok is not) {
            return TokenKind.EOF
        }
        return tok.kind
    }

    // currentKind — calculation (read): the `.kind` of the current token.
    export fn currentKind(cursor) {
        return peekKind(cursor, 0)
    }

    // isKind — calculation (predicate): is the current token of `kind`?
    export fn isKind(cursor, kind) {
        return currentKind(cursor) == kind
    }

    // previous — calculation (read): the token immediately BEFORE the
    // cursor's position (the one most recently advance()'d past), or `not`
    // at start-of-stream. Added at MK4 (R1 spike §1.2) — the JS->markup
    // `<`-vs-`LessThan` discriminator (markupValueAllowedAfter) needs the
    // prev-token kind to decide whether a `<` opens a markup value.
    export fn previous(cursor) {
        if (cursor.idx <= 0) return not
        if (cursor.idx > cursor.tokens.length) return not
        return cursor.tokens[cursor.idx - 1]
    }

    // previousKind — calculation (read): the kind of the previous token,
    // or `not` for start-of-stream. markupValueAllowedAfter treats `not` /
    // undefined as a value-following position (start-of-body is a legal
    // markup-value position).
    export fn previousKind(cursor) {
        const tok = previous(cursor)
        if (tok is not) return not
        return tok.kind
    }

    // isKindAt — calculation (predicate): is the token at `idx + k` of `kind`?
    export fn isKindAt(cursor, k, kind) {
        return peekKind(cursor, k) == kind
    }

    // advance — STATE write: the cursor's index transitions forward by
    // `n` (default 1). Never advances past the EOF token's index — once
    // `atEnd` is true the index is clamped. Per V5-strict the body would
    // be `@tokenCursor.idx = ...`; the live-surface mutation mirrors that.
    // Returns the token that WAS current before the advance (the consumed
    // token) — the common "consume + use" idiom.
    export fn advance(cursor, n) {
        const steps = n ?? 1
        const consumed = current(cursor)
        let i = 0
        while (i < steps) {
            if (cursor.idx < cursor.tokens.length - 1) {
                cursor.idx = cursor.idx + 1
            }
            i = i + 1
        }
        return consumed
    }

    // snapshot — capture a checkpoint (idx). Per DD §D4 P3 / OQ3, bounded
    // lookahead-with-commit is the parser's speculation primitive. In
    // canonical scrml the snapshot is lin-typed (§35); the live surface
    // returns a plain {idx} object.
    export fn snapshot(cursor) {
        return { idx: cursor.idx }
    }

    // restore — apply a snapshot back to a cursor (STATE write). The
    // lin-typed canonical form CONSUMES the snapshot here (designing out
    // double-restore); the live surface just writes `idx`.
    export fn restore(cursor, snap) {
        cursor.idx = snap.idx
    }
}
