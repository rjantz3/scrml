// ast-stmt.scrml ‚Äî Stmt AST node catalog (DD ¬ßD3 type catalog).
//
// PILLAR 5b classification (DD ¬ßD1):
//   The Stmt enum + its node constructors are PURE DATA + CALCULATION ‚Äî
//   identical classification to ast-expr.scrml. A Stmt node is a struct-
//   typed discriminated-union value describing an already-parsed statement.
//   It has NO ongoing identity, NO transitions, NO lifecycle, and there is
//   NO sensible "what condition is this node in right now?" question. Per
//   DD ¬ßD1 the negative example "AST node construction from already-
//   confirmed parts (makeIfStmt) is a pure constructor ‚Äî calculation"
//   applies verbatim ‚Äî and names a Stmt constructor explicitly.
//
//   What IS state (and lives in parse-mode.scrml, NOT here): the ParseMode
//   the statement parser is currently in. The AST nodes this file
//   constructs are the OUTPUT of the parse ‚Äî pure values, not state.
//
// Status (M3.1 + M3.2 + M3.3): COMPILABLE skeleton. JS-escape carries the
// live tag-style surface. The `type Stmt:enum = { ... }` declaration is
// preserved in commented canonical form for the M5 swap-in to scrml-native
// tagged variants. M3.1 emitted the substrate kinds (Block, ExprStmt, Empty,
// VarDecl) + the binding-pattern catalog (ObjectPattern / ArrayPattern /
// AssignmentPattern / RestElement and the property/element forms). M3.2 ADDS
// the control-flow constructors (If / While / DoWhile / For / ForIn / ForOf
// / Return / Break / Continue / Labeled). M3.3 ADDS the declaration / module
// / legacy-error constructors (FunctionDecl / ClassDecl / Import / Export /
// Try / Throw) + the class-member / import-specifier / export-specifier /
// catch-clause sub-shapes. The Stmt enum is now whole ‚Äî every kind the M3
// chain produces has both an enum tag and a constructor.
//
// DD ¬ßD3 cross-ref: the S98 DD ¬ßD3 `Stmt` enum sketch ‚Äî ExprStmt / VarDecl /
// If / For / Return / Block ‚Äî is the design seed; M3.1 expands it to the
// full D5 MUST-PARSE statement surface. The native parser's Stmt enum is the
// M5 swap-in target shape; the M3.x CONFORMANCE oracle is Acorn's ESTree
// output (DD ¬ßD6). The native enum is intentionally MORE typed than
// ESTree's `type: string` discriminator.

${
    // CANONICAL scrml-source shape (PILLAR 5b reference) ‚Äî tagged-variant
    // enum per DD ¬ßD3. PRESERVED in commented form pending the M5 swap-in
    // (payload-bearing variants reach the limits of what the compiler
    // accepts today; for M3.1 the live surface below is plain JS, mirroring
    // ast-expr.scrml's concession).
    //
    //   type Stmt:enum = {
    //       // --- M3.1 ‚Äî statement substrate ---
    //       Block(body: Stmt[], span: Span),
    //       ExprStmt(expression: Expr, span: Span),
    //       Empty(span: Span),
    //       VarDecl(declKind: VarDeclKind, declarations: VarDeclarator[], span: Span),
    //
    //       // --- M3.2 ‚Äî control-flow statements ---
    //       If(test: Expr, consequent: Stmt, alternate: Stmt | not, span: Span),
    //       While(test: Expr, body: Stmt, span: Span),
    //       DoWhile(body: Stmt, test: Expr, span: Span),
    //       For(init: Stmt | Expr | not, test: Expr | not,
    //           update: Expr | not, body: Stmt, span: Span),
    //       ForIn(left: Stmt | Binding, right: Expr, body: Stmt, span: Span),
    //       ForOf(left: Stmt | Binding, right: Expr, body: Stmt,
    //             isAwait: boolean, span: Span),   // isAwait ‚Äî M3.2
    //       Return(argument: Expr | not, span: Span),
    //       Break(label: string | not, span: Span),
    //       Continue(label: string | not, span: Span),
    //       Labeled(label: string, body: Stmt, span: Span),
    //
    //       // --- M3.3 ‚Äî declarations + module syntax + legacy error flow ---
    //       FunctionDecl(name: string, params: Pattern[], body: Stmt[],
    //                    isAsync: boolean, isGenerator: boolean, span: Span),
    //       ClassDecl(name: string, superClass: Expr | not,
    //                 body: ClassMember[], span: Span),
    //       Import(specifiers: ImportSpecifier[], source: string, span: Span),
    //       Export(declaration: Stmt | not, specifiers: ExportSpecifier[],
    //              source: string | not, span: Span),
    //       Try(block: Stmt, handler: CatchClause | not,
    //           finalizer: Stmt | not, span: Span),
    //       Throw(argument: Expr, span: Span),
    //   }
    //
    //   type VarDeclKind:enum = { Let, Const, Var }
    //
    //   type VarDeclarator:struct = {
    //       target: Binding, init: Expr | not, span: Span,
    //   }
    //
    //   // --- binding-pattern grammar (declaration targets ‚Äî S98 DD ¬ßD5) ---
    //   type Binding:enum = {
    //       Ident(name: string, span: Span),
    //       ObjectPat(properties: BindingProperty[], span: Span),
    //       ArrayPat(elements: BindingElement[], span: Span),
    //       AssignmentPattern(left: Binding, right: Expr, span: Span),
    //       RestElement(argument: Binding, span: Span),
    //   }
    //   type BindingProperty:enum = {
    //       KeyValue(key: Expr, value: Binding, computed: boolean),
    //       Shorthand(name: string, value: Binding),
    //       Rest(argument: Binding),
    //   }
    //   type BindingElement:enum = {
    //       Item(value: Binding),
    //       Hole,                                  // elision: [ , x ]
    //       Rest(argument: Binding),
    //   }
    //
    //   // --- M3.3 class-member / module sub-shapes ---
    //   type ClassMember:enum = {
    //       Method(key: Expr, value: Expr, methodKind: MethodKind,
    //              isStatic: boolean, computed: boolean, span: Span),
    //       Property(key: Expr, value: Expr | not,
    //                isStatic: boolean, computed: boolean, span: Span),
    //   }
    //   type MethodKind:enum = { Constructor, Method, Get, Set }
    //   type ImportSpecifier:enum = {
    //       Named(imported: string, local: string, span: Span),
    //       Default(local: string, span: Span),
    //       Namespace(local: string, span: Span),
    //   }
    //   type ExportSpecifier:struct = {
    //       local: string, exported: string, span: Span,
    //   }
    //   type CatchClause:struct = {
    //       param: Binding | not, body: Stmt, span: Span,
    //   }
    //
    // LIVE M3.1 SURFACE (JS host) ‚Äî a Stmt node is a plain JS object with
    // `kind` as a string tag (one of the StmtKind variant names below).
    // Payload fields ride alongside `kind` per-variant. Every node carries
    // `span: Span` (reuses span.scrml's struct). Binding nodes carry a
    // `bindingKind` tag rather than `kind` (they are not Stmt nodes).
    //
    // Pillar 5b note: kind-as-string-tag is a known M3.1 concession to the
    // M5 self-host swap ‚Äî identical to ast-expr.scrml's concession.

    // ---------------------------------------------------------------------
    // StmtKind ‚Äî string-tag registry. Order mirrors the canonical enum.
    // M3.1 EMITS Block / ExprStmt / Empty / VarDecl; M3.2 EMITS the
    // control-flow kinds; the M3.3 kinds are declared for catalog
    // completeness (constructors land M3.3).
    // ---------------------------------------------------------------------
    export const StmtKind = Object.freeze({
        // --- M3.1 ‚Äî statement substrate ---
        Block:    "Block",
        ExprStmt: "ExprStmt",
        Empty:    "Empty",
        VarDecl:  "VarDecl",

        // --- M3.2 ‚Äî control-flow statements ---
        If:       "If",
        While:    "While",
        DoWhile:  "DoWhile",
        For:      "For",
        ForIn:    "ForIn",
        ForOf:    "ForOf",
        Return:   "Return",
        Break:    "Break",
        Continue: "Continue",
        Labeled:  "Labeled",

        // --- M3.3 ‚Äî declarations + module syntax + legacy error flow ---
        FunctionDecl: "FunctionDecl",
        ClassDecl:    "ClassDecl",
        Import:       "Import",
        Export:       "Export",
        Try:          "Try",
        Throw:        "Throw",
    })

    // VarDeclKind ‚Äî the `let` / `const` / `var` declaration keyword (M3.1).
    export const VarDeclKind = Object.freeze({
        Let:   "let",
        Const: "const",
        Var:   "var",
    })

    // ClassMemberKind ‚Äî discriminator for one class-body member (M3.3).
    // Method (incl. constructor / static / get/set / generator / async /
    // computed-name) or Property (a class field).
    export const ClassMemberKind = Object.freeze({
        Method:   "Method",
        Property: "Property",
    })

    // MethodKind ‚Äî the role of a class Method member (ESTree
    // MethodDefinition `kind`): constructor / plain method / get/set accessor.
    export const MethodKind = Object.freeze({
        Constructor: "constructor",
        Method:      "method",
        Get:         "get",
        Set:         "set",
    })

    // ImportSpecifierKind ‚Äî one specifier of an `import` (M3.3): a Named
    // import, the Default import, or the Namespace import.
    export const ImportSpecifierKind = Object.freeze({
        Named:     "Named",
        Default:   "Default",
        Namespace: "Namespace",
    })

    // BindingKind ‚Äî discriminator for a variable-declaration binding TARGET.
    // M3.1 parses real binding patterns per S98 DD ¬ßD5.
    export const BindingKind = Object.freeze({
        Ident:     "Ident",
        ObjectPat: "ObjectPat",
        ArrayPat:  "ArrayPat",
    })

    // BindingPropertyKind ‚Äî one property of an object-destructuring pattern.
    export const BindingPropertyKind = Object.freeze({
        KeyValue:  "KeyValue",
        Shorthand: "Shorthand",
        Rest:      "Rest",
    })

    // BindingElementKind ‚Äî one element of an array-destructuring pattern.
    export const BindingElementKind = Object.freeze({
        Item: "Item",
        Hole: "Hole",
        Rest: "Rest",
    })

    // -- Statement node constructors (M3.1) --

    // makeBlock ‚Äî a block statement `{ stmt* }`.
    export function makeBlock(body, span) {
        return { kind: StmtKind.Block, body, span }
    }

    // makeExprStmt ‚Äî an expression statement `expr ;`.
    export function makeExprStmt(expression, span) {
        return { kind: StmtKind.ExprStmt, expression, span }
    }

    // makeEmpty ‚Äî the empty statement `;`.
    export function makeEmpty(span) {
        return { kind: StmtKind.Empty, span }
    }

    // makeVarDecl ‚Äî a `let`/`const`/`var` declaration.
    export function makeVarDecl(declKind, declarations, span) {
        return { kind: StmtKind.VarDecl, declKind, declarations, span }
    }

    // makeVarDeclarator ‚Äî one declarator: a binding target + optional init.
    export function makeVarDeclarator(target, init, span) {
        return { target, init, span }
    }

    // -- Control-flow statement node constructors (M3.2 ‚Äî DD ¬ßD3 / ¬ßD5) --

    // makeIf ‚Äî an `if (test) consequent else alternate` statement. `alternate`
    // is `not` for a no-else `if`; an `else if` chain nests an If as the
    // alternate (Acorn's IfStatement shape).
    export function makeIf(test, consequent, alternate, span) {
        return { kind: StmtKind.If, test, consequent, alternate, span }
    }

    // makeWhile ‚Äî a `while (test) body` loop.
    export function makeWhile(test, body, span) {
        return { kind: StmtKind.While, test, body, span }
    }

    // makeDoWhile ‚Äî a `do body while (test)` loop (body runs once first).
    export function makeDoWhile(body, test, span) {
        return { kind: StmtKind.DoWhile, body, test, span }
    }

    // makeFor ‚Äî a C-style three-clause `for (init; test; update) body` loop.
    // Each of `init` / `test` / `update` is `not` when its clause is empty.
    // `init` is a VarDecl Stmt or an Expr; `test` / `update` are Exprs.
    export function makeFor(init, test, update, body, span) {
        return { kind: StmtKind.For, init, test, update, body, span }
    }

    // makeForIn ‚Äî a `for (left in right) body` loop. `left` is a VarDecl Stmt
    // or an assignment-target Expr; `right` is the iterated object.
    export function makeForIn(left, right, body, span) {
        return { kind: StmtKind.ForIn, left, right, body, span }
    }

    // makeForOf ‚Äî a `for (left of right) body` loop. `isAwait` is true for
    // `for await (left of right)` (an M3.2 extension of the DD ¬ßD3 ForOf
    // shape ‚Äî mirrors Acorn's ForOfStatement `await: boolean`; the body
    // `async` context is M3.3's territory).
    export function makeForOf(left, right, body, isAwait, span) {
        return { kind: StmtKind.ForOf, left, right, body, isAwait, span }
    }

    // makeReturn ‚Äî a `return argument` statement. `argument` is `not` for a
    // bare `return`.
    export function makeReturn(argument, span) {
        return { kind: StmtKind.Return, argument, span }
    }

    // makeBreak ‚Äî a `break` (optionally `break label`). `label` is `not` for
    // an unlabeled break.
    export function makeBreak(label, span) {
        return { kind: StmtKind.Break, label, span }
    }

    // makeContinue ‚Äî a `continue` (optionally `continue label`). `label` is
    // `not` for an unlabeled continue.
    export function makeContinue(label, span) {
        return { kind: StmtKind.Continue, label, span }
    }

    // makeLabeled ‚Äî a `label: body` labeled statement. `label` is the label
    // identifier text; `body` is the statement the label names.
    export function makeLabeled(label, body, span) {
        return { kind: StmtKind.Labeled, label, body, span }
    }

    // -- Declaration / module / legacy-error node constructors (M3.3) --
    //
    // Function/class declaration bodies are parsed IN-LINE ‚Äî `body` is a Stmt
    // array, NOT a token-range stub. This is THE body-pre-parser subsumption:
    // M3 parses function bodies in-line so body-pre-parser.ts deletes by
    // construction (DD ¬ßD7 M3 gating). `try`/`catch`/`finally`+`throw` are
    // parsed for legacy + JS-import inputs; a later stage (the typer) rejects
    // them in scrml source (scrml uses `fail`/`!{}` per SPEC ¬ß19).

    // makeFunctionDecl ‚Äî a `function name(params) { body }` declaration.
    // `body` is the function body's Stmt array (parsed in-line). `isAsync` is
    // true for `async function`; `isGenerator` is true for `function*`.
    export function makeFunctionDecl(name, params, body, isAsync, isGenerator, span) {
        return { kind: StmtKind.FunctionDecl, name, params, body, isAsync, isGenerator, span }
    }

    // makeClassDecl ‚Äî a `class Name extends Base { ... }` declaration.
    // `superClass` is the extends-clause Expr or `not`; `body` is a
    // ClassMember array.
    export function makeClassDecl(name, superClass, body, span) {
        return { kind: StmtKind.ClassDecl, name, superClass, body, span }
    }

    // makeImport ‚Äî an `import ... from "source"` statement. `specifiers` is an
    // import-specifier array (empty for a bare `import "m"`); `source` is the
    // module-specifier string value.
    export function makeImport(specifiers, source, span) {
        return { kind: StmtKind.Import, specifiers, source, span }
    }

    // makeExport ‚Äî an `export ...` statement. `declaration` is the exported
    // Stmt or `not`; `specifiers` is the export-specifier list (`export {}`);
    // `source` is the re-export module string or `not`; `isDefault` is true
    // for `export default`.
    export function makeExport(declaration, specifiers, source, isDefault, span) {
        return { kind: StmtKind.Export, declaration, specifiers, source, isDefault, span }
    }

    // makeTry ‚Äî a `try { } catch (param) { } finally { }` statement. `block`
    // is the try-block Stmt; `handler` is a catch-clause object or `not`;
    // `finalizer` is the finally-block Stmt or `not`.
    export function makeTry(block, handler, finalizer, span) {
        return { kind: StmtKind.Try, block, handler, finalizer, span }
    }

    // makeThrow ‚Äî a `throw argument` statement. `argument` is the thrown-value
    // Expr (the no-LineTerminator restricted production gates it).
    export function makeThrow(argument, span) {
        return { kind: StmtKind.Throw, argument, span }
    }

    // -- Class-member node constructors (M3.3) --

    // makeMethodDef ‚Äî one method member of a class body. `key` is the
    // method-name node; `value` is the method's Function Expr (params +
    // in-line body); `methodKind` is a MethodKind value; `isStatic` /
    // `computed` are booleans.
    export function makeMethodDef(key, value, methodKind, isStatic, computed, span) {
        return {
            memberKind: ClassMemberKind.Method,
            key, value, methodKind, isStatic, computed, span,
        }
    }

    // makePropertyDef ‚Äî one class-field member. `key` is the field-name node;
    // `value` is the initializer Expr or `not`; `isStatic` / `computed` are
    // booleans.
    export function makePropertyDef(key, value, isStatic, computed, span) {
        return {
            memberKind: ClassMemberKind.Property,
            key, value, isStatic, computed, span,
        }
    }

    // -- Import-specifier / export-specifier / catch-clause constructors --

    // makeImportNamed ‚Äî a named import specifier `imported as local`.
    export function makeImportNamed(imported, local, span) {
        return { specifierKind: ImportSpecifierKind.Named, imported, local, span }
    }

    // makeImportDefault ‚Äî the default-import specifier `import local`.
    export function makeImportDefault(local, span) {
        return { specifierKind: ImportSpecifierKind.Default, local, span }
    }

    // makeImportNamespace ‚Äî the namespace-import specifier `import * as local`.
    export function makeImportNamespace(local, span) {
        return { specifierKind: ImportSpecifierKind.Namespace, local, span }
    }

    // makeExportSpecifier ‚Äî one specifier of `export { ... }`: `local as
    // exported`.
    export function makeExportSpecifier(local, exported, span) {
        return { local, exported, span }
    }

    // makeCatchClause ‚Äî the `catch (param) { body }` clause of a `try`.
    // `param` is the caught-binding target or `not` (optional-catch-binding);
    // `body` is the catch-block Stmt.
    export function makeCatchClause(param, body, span) {
        return { param, body, span }
    }

    // -- Binding-pattern node constructors (M3.1 ‚Äî DD ¬ßD5) --

    // makeBindingIdent ‚Äî a plain identifier binding `x` (the pattern leaf).
    export function makeBindingIdent(name, span) {
        return { bindingKind: BindingKind.Ident, name, span }
    }

    // makeObjectPattern ‚Äî `{ a, b: c, ...rest }` destructuring pattern.
    export function makeObjectPattern(properties, span) {
        return { bindingKind: BindingKind.ObjectPat, properties, span }
    }

    // makeArrayPattern ‚Äî `[ a, , b, ...rest ]` destructuring pattern.
    export function makeArrayPattern(elements, span) {
        return { bindingKind: BindingKind.ArrayPat, elements, span }
    }

    // makeAssignmentPattern ‚Äî a defaulted binding `target = default`.
    export function makeAssignmentPattern(left, right, span) {
        return { bindingKind: "AssignmentPattern", left, right, span }
    }

    // makeRestElement ‚Äî a rest binding `...target`.
    export function makeRestElement(argument, span) {
        return { bindingKind: "RestElement", argument, span }
    }

    // -- object-pattern property constructors --

    // makeBindingPropertyKeyValue ‚Äî `{ key: target }`.
    export function makeBindingPropertyKeyValue(key, value, computed) {
        return { propertyKind: BindingPropertyKind.KeyValue, key, value, computed }
    }

    // makeBindingPropertyShorthand ‚Äî `{ name }` (or `{ name = default }`).
    export function makeBindingPropertyShorthand(name, value) {
        return { propertyKind: BindingPropertyKind.Shorthand, name, value }
    }

    // makeBindingPropertyRest ‚Äî `{ ...rest }`.
    export function makeBindingPropertyRest(argument) {
        return { propertyKind: BindingPropertyKind.Rest, argument }
    }

    // -- array-pattern element constructors --

    // makeBindingElementItem ‚Äî one positional element of an array pattern.
    export function makeBindingElementItem(value) {
        return { elementKind: BindingElementKind.Item, value }
    }

    // makeBindingElementHole ‚Äî an elision slot `[ , x ]`.
    export function makeBindingElementHole() {
        return { elementKind: BindingElementKind.Hole }
    }

    // makeBindingElementRest ‚Äî `[ ...rest ]`.
    export function makeBindingElementRest(argument) {
        return { elementKind: BindingElementKind.Rest, argument }
    }

    // -- isStmt ‚Äî predicate --
    export function isStmt(node) {
        if (node is not) {
            return false
        }
        return StmtKind[node.kind] is not not
    }
}
