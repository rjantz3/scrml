node_modules/
dist/
.claude/
.DS_Store
*.log
.env
.env.local

# VS Code extension build artifacts
editors/vscode/out/
editors/vscode/bun.lock

# SEO-LAUNCH.md — local marketing draft; not tracked. 10 sessions stale at S32 wrap.
docs/SEO-LAUNCH.md

# scripts/bundle-size-benchmark.js output — regenerated on every run.
# The curated, committed benchmark file is benchmarks/RESULTS.md; this is a
# raw per-run dump that should never be tracked (S109 wrap hygiene).
docs/m1-benchmark-results.md

# Per-dispatch agent scratchpad — not tracked
.tmp/

# Test fixture scratchpads written at runtime by test harnesses (e.g.,
# debounce-throttle-attribute.test.js compileInline). Regenerated each run.
compiler/tests/unit/__fixtures__/

# Playwright e2e — generated test artifacts (Wave 3 Dispatch 1 + S100 docs harness)
e2e/test-results/
e2e/playwright-report/
e2e/test-results-docs/
e2e/playwright-report-docs/
e2e/blob-report/
e2e/.playwright/
playwright/.cache/

# Runtime SQLite databases — examples + benchmarks create these on e2e + dev runs
*.db
*.db-journal
*.db-wal
*.db-shm

# docs/build.ts output — generated per-article HTML pages.
# Source: docs/articles/*.md. Build: `bun run docs/build.ts`.
# Tracked nowhere; rebuilt on demand. Landing page (docs/index.html) IS tracked.
docs/articles/*/
docs/articles/index.html
