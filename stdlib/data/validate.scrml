<program>
${
    // ---------------------------------------------------------------------------
    // scrml:data/validate — validation rule builders and schema validator
    //
    // Returns a ValidationResult: { [fieldName]: string[] } where each field
    // maps to an array of error messages. Empty object = all valid.
    //
    // Usage:
    //   import { validate, required, email, minLength } from 'scrml:data'
    //
    //   const errors = validate(
    //       { email: @email, password: @password },
    //       { email: [required(), email()], password: [required(), minLength(8)] }
    //   )
    //   if (Object.keys(errors).length > 0) { @formErrors = errors }
    // ---------------------------------------------------------------------------

    /**
     * Run all validation rules against a data object.
     *
     * @param data - Object of field values { fieldName: value }
     * @param schema - Object of rule arrays { fieldName: [rule, rule, ...] }
     * @returns { [fieldName]: string[] } — empty object if all valid
     */
    export function validate(data, schema) {
        const errors = {}
        for (const field of Object.keys(schema)) {
            const value = data[field]
            const rules = schema[field]
            for (const rule of rules) {
                const result = rule.check(value, data)
                if (!result.valid) {
                    errors[field] = errors[field] || []
                    errors[field].push(result.message)
                }
            }
        }
        return errors
    }

    /**
     * Check if a validation result has any errors.
     * Useful as a guard before form submission.
     */
    export function isValid(result) {
        return Object.keys(result).length == 0
    }

    /**
     * Get the first error for a field, or null if valid.
     * Convenient for displaying single-error UIs.
     */
    export function firstError(result, field) {
        const errs = result[field]
        return errs && errs.length > 0 ? errs[0] : null
    }

    // ---------------------------------------------------------------------------
    // Rule builders — each returns a { check(value, data): { valid, message } }
    // ---------------------------------------------------------------------------

    function makeRule(check) {
        return { check }
    }

    /**
     * Field is required (not null, undefined, or empty string).
     */
    export function required(message) {
        return makeRule((value) => {
            const valid = value != null && value != undefined && value != ""
            return { valid, message: message || "This field is required" }
        })
    }

    /**
     * Valid email address format.
     */
    export function email(message) {
        return makeRule((value) => {
            if (!value) return { valid: true, message: "" }
            const valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(String(value))
            return { valid, message: message || "Enter a valid email address" }
        })
    }

    /**
     * Minimum string length.
     */
    export function minLength(min, message) {
        return makeRule((value) => {
            if (!value) return { valid: true, message: "" }
            const valid = String(value).length >= min
            return { valid, message: message || `Must be at least ${min} characters` }
        })
    }

    /**
     * Maximum string length.
     */
    export function maxLength(max, message) {
        return makeRule((value) => {
            if (!value) return { valid: true, message: "" }
            const valid = String(value).length <= max
            return { valid, message: message || `Must be at most ${max} characters` }
        })
    }

    /**
     * Exact string length.
     */
    export function exactLength(len, message) {
        return makeRule((value) => {
            if (!value) return { valid: true, message: "" }
            const valid = String(value).length == len
            return { valid, message: message || `Must be exactly ${len} characters` }
        })
    }

    /**
     * Value matches a regular expression.
     */
    export function pattern(regex, message) {
        return makeRule((value) => {
            if (!value) return { valid: true, message: "" }
            const valid = regex.test(String(value))
            return { valid, message: message || "Invalid format" }
        })
    }

    /**
     * Numeric minimum value.
     */
    export function min(minimum, message) {
        return makeRule((value) => {
            const num = Number(value)
            const valid = !isNaN(num) && num >= minimum
            return { valid, message: message || `Must be at least ${minimum}` }
        })
    }

    /**
     * Numeric maximum value.
     */
    export function max(maximum, message) {
        return makeRule((value) => {
            const num = Number(value)
            const valid = !isNaN(num) && num <= maximum
            return { valid, message: message || `Must be at most ${maximum}` }
        })
    }

    /**
     * Value must be a valid number.
     */
    export function numeric(message) {
        return makeRule((value) => {
            if (value == "" || value == null || value == undefined) return { valid: true, message: "" }
            const valid = !isNaN(Number(value)) && value != ""
            return { valid, message: message || "Must be a number" }
        })
    }

    /**
     * Value must be a valid integer.
     */
    export function integer(message) {
        return makeRule((value) => {
            if (value == "" || value == null || value == undefined) return { valid: true, message: "" }
            const valid = Number.isInteger(Number(value))
            return { valid, message: message || "Must be a whole number" }
        })
    }

    /**
     * Value must match another field (e.g., password confirmation).
     * Receives the entire data object as second argument.
     */
    export function matches(fieldName, message) {
        return makeRule((value, data) => {
            const valid = value == data[fieldName]
            return { valid, message: message || `Must match ${fieldName}` }
        })
    }

    /**
     * Value must be in a list of allowed values.
     */
    export function oneOf(allowedValues, message) {
        return makeRule((value) => {
            const valid = allowedValues.includes(value)
            return { valid, message: message || `Must be one of: ${allowedValues.join(", ")}` }
        })
    }

    /**
     * Value must be a URL.
     */
    export function url(message) {
        return makeRule((value) => {
            if (!value) return { valid: true, message: "" }
            try {
                new URL(String(value))
                return { valid: true, message: "" }
            } catch {
                return { valid: false, message: message || "Enter a valid URL" }
            }
        })
    }

    /**
     * Custom validation rule. fn receives (value, data) and returns
     * true (valid) or a string (error message).
     */
    export function custom(fn) {
        return makeRule((value, data) => {
            const result = fn(value, data)
            if (result == true) return { valid: true, message: "" }
            return { valid: false, message: typeof result == "string" ? result : "Invalid value" }
        })
    }

    // ---------------------------------------------------------------------------
    // Bridging external schema libraries (zod, valibot, arktype, etc.)
    // ---------------------------------------------------------------------------
    //
    // scrml does NOT ship a curated zod / standard-schema stdlib adapter. The
    // existing `custom(fn)` slot above absorbs the bridge in 5 lines. Per
    // SPEC §53.14.4 (synonym-detection canon) and design-insight 28
    // (2026-05-09): a curated stdlib export would be a synonym for
    // `custom(fn)`, not a sliver — closed by the synonym-detection rule.
    //
    // Pattern (verbatim, paste into your scrml file):
    //
    //     ${
    //         import { z } from 'zod'  // or valibot, arktype, etc.
    //         import { custom } from 'scrml:data'
    //
    //         function fromSchema(schema) {
    //             return custom((value) => {
    //                 const r = schema.safeParse(value)
    //                 return r.success ? true : r.error.issues[0].message
    //             })
    //         }
    //     }
    //
    //     <signup>
    //         <email custom(fromSchema(z.string().email()))> = <input/>
    //     </>
    //
    // For Standard-Schema-shaped libraries, swap `safeParse` for the
    // `~standard.validate` interop call. See standardschema.dev.
    //
    // Trade-offs (these apply to ANY bridged validator, not just zod):
    //
    //   - Bridged validators do NOT lower to schema-column DDL. SPEC §39.5.8
    //     CHECK constraints cannot call JS. A field declared with a bridged
    //     validator gets cell-level + refinement-level enforcement only;
    //     DBMS-level enforcement stays scrml-native or absent.
    //
    //   - Bridged validators do NOT inform HTML attribute inference.
    //     SPEC §53.7 native predicates auto-emit `min=`, `maxlength=`,
    //     `pattern=`, `required` etc. on bindable cells. Bridged schemas
    //     are opaque to scrml's compiler; their constraints stay runtime-
    //     only. You lose free HTML validation.
    //
    //   - Bridged errors land as `ValidationError::Custom(message)` per
    //     SPEC §55.9, not as structured-payload variants like
    //     `.MinFailed(threshold)`. Programmatic access to the threshold
    //     (e.g., to render a numeric input's `min=` attribute) is lost.
    //
    //   - Cross-locus consistency (L4) breaks at bridged validators —
    //     same shape as `custom(fn)` itself. The docs page is the
    //     mitigation regardless of bridge-or-not.
    //
    // For fields that need cross-locus enforcement (cell + refinement +
    // schema column + HTML), use scrml-native predicates (`length`,
    // `pattern`, `min`, `max`, named shapes). For sum-type boundary
    // parsing of incoming JSON (different mechanism, different locus),
    // see `parseVariant(json, EnumType)` per SPEC §41.13.
    //
    // Re-debate trigger (design-insight 28 OQ-bridge-2): if ≥3 adopters
    // report the wrapper above as friction-felt at scale, the bridge
    // question reopens. Elevate the Standard-Schema-via-`custom(...)`-
    // type-dispatch shape on re-fire — NOT the per-library shape.

    // ---------------------------------------------------------------------------
    // Convenience: pre-built rule sets for common fields
    // ---------------------------------------------------------------------------

    /**
     * Standard email field rules: required + email format.
     */
    export function emailField() {
        return [required(), email()]
    }

    /**
     * Standard password field rules: required + minimum 8 chars.
     */
    export function passwordField(minLen) {
        return [required(), minLength(minLen || 8)]
    }

    /**
     * Standard password confirmation rules: required + matches "password" field.
     */
    export function passwordConfirmField(fieldName) {
        return [required(), matches(fieldName || "password", "Passwords must match")]
    }

    ~{
        import { assertEqual, assertTruthy, assertFalsy } from 'scrml:test'

        // required rule
        const req = required()
        assertEqual(req.check(""), { valid: false, message: "This field is required" })
        assertEqual(req.check(null), { valid: false, message: "This field is required" })
        assertEqual(req.check("hello"), { valid: true, message: "This field is required" })

        // email rule
        const em = email()
        assertEqual(em.check("test@example.com"), { valid: true, message: "Enter a valid email address" })
        assertEqual(em.check("notanemail").valid, false)
        assertEqual(em.check("").valid, true)  // empty is OK — pair with required()

        // minLength
        const ml = minLength(3)
        assertEqual(ml.check("ab").valid, false)
        assertEqual(ml.check("abc").valid, true)
        assertEqual(ml.check("").valid, true)  // empty is OK — pair with required()

        // validate() integration
        const errors = validate(
            { email: "", password: "ab" },
            { email: [required(), email()], password: [required(), minLength(8)] }
        )
        assertEqual(errors.email, ["This field is required"])
        assertEqual(errors.password, ["Must be at least 8 characters"])

        const clean = validate(
            { email: "a@b.com", password: "secure123" },
            { email: [required(), email()], password: [required(), minLength(8)] }
        )
        assertTruthy(isValid(clean))

        // matches rule
        const confirmRule = matches("password", "Passwords must match")
        assertEqual(confirmRule.check("x", { password: "x" }).valid, true)
        assertEqual(confirmRule.check("x", { password: "y" }).valid, false)

        // oneOf rule
        const roleRule = oneOf(["admin", "user", "viewer"])
        assertEqual(roleRule.check("admin").valid, true)
        assertEqual(roleRule.check("superuser").valid, false)

        // firstError helper
        const res = validate({ name: "" }, { name: [required()] })
        assertEqual(firstError(res, "name"), "This field is required")
        assertEqual(firstError(res, "email"), null)
    }
}
</program>
