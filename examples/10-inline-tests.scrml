// Example 10: Inline tests — ~{} test sigil stripped from production.
// A counter with reactive state. Tests verify state transitions directly.
// ~{} blocks are compile-time artifacts: present in dev, absent in production output.
// Styled with Tailwind utility classes.

<program>

${
    <count> = 0
    <step>  = 1

    function increment() { @count = @count + @step }
    function decrement() { @count = @count - @step }
    // `reset` is a reserved keyword (§6.8); use a distinct local name.
    // reset(@cell) is the canonical reset keyword form.
    function clearCount() { reset(@count) }
    function setStep(n)  { @step = n }
}

<div class="flex flex-col items-center gap-4 p-8">
    <h2 class="text-2xl font-bold text-gray-800">Counter</>
    <p class="text-5xl font-bold text-blue-600">${@count}</>

    <div class="flex gap-2">
        <button class="px-5 py-2 text-lg cursor-pointer border border-gray-300 rounded bg-white hover:bg-gray-100" onclick=decrement()>−</button>
        <button class="px-5 py-2 text-lg cursor-pointer border border-gray-300 rounded bg-white hover:bg-gray-100" onclick=clearCount()>Reset</button>
        <button class="px-5 py-2 text-lg cursor-pointer border border-gray-300 rounded bg-white hover:bg-gray-100" onclick=increment()>+</button>
    </div>

    <label class="flex items-center gap-2 text-sm">
        Step size:
        <input type="number" class="w-16 p-1 text-center border border-gray-300 rounded" bind:value=@step min="1" max="10">
    </label>
</div>

// Inline tests. These do not ship. The compiler strips ~{} from production builds.
// Tests run during `bun test` against the compiled module.
~{ "counter — state transitions"
    test "initial count is 0" {
        assert @count == 0
    }

    test "increment adds step" {
        @count = 0
        @step  = 1
        increment()
        assert @count == 1
    }

    test "decrement subtracts step" {
        @count = 5
        @step  = 2
        decrement()
        assert @count == 3
    }

    test "clearCount returns to 0 regardless of count" {
        @count = 99
        clearCount()
        assert @count == 0
    }

    test "step size affects increment" {
        @count = 0
        setStep(5)
        increment()
        assert @count == 5
    }

    test "count cannot go below 0 via decrement" {
        // Language doesn't enforce this — note the assumption so product can decide.
        // For now this test documents observed behavior, not a guarantee.
        @count = 0
        @step  = 1
        decrement()
        assert @count == -1   // currently allowed; clamping would need a guard in decrement()
    }
}

</program>
