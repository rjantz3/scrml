// Trucking Dispatch — invoice card (M2).
//
// Table-row shape used by /dispatch/billing and (M4) the customer invoices
// page. Shows amount, sent_at, due_at, paid_at-or-Outstanding,
// payment_reference. The "Mark paid" button is dispatcher-only.

${
    import { formatRate } from './load-card.scrml'
    import { InvoiceStatus } from '../schema.scrml'

    // Derives the visible status for an invoice — a DERIVED enum, computed from
    // paid_at / due_at at render time, never stored in a column (no DB
    // migration). Returns the InvoiceStatus VARIANT directly.
    //   .Paid        — paid_at present
    //   .Overdue     — paid_at absent AND due_at < today
    //   .Outstanding — paid_at absent AND due_at >= today
    export fn invoiceStatus(inv: asIs, todayIso: string) -> InvoiceStatus {
        if (inv.paid_at is some && inv.paid_at != "") return .Paid
        if (inv.due_at is some && inv.due_at != "" && inv.due_at < todayIso) return .Overdue
        return .Outstanding
    }

    // Pill classes — `match` over the InvoiceStatus variant is exhaustive.
    export fn invoiceStatusClasses(status: InvoiceStatus) -> string {
        return match status {
            .Paid        :> "bg-emerald-100 text-emerald-800 border-emerald-200"
            .Overdue     :> "bg-red-100 text-red-800 border-red-200"
            .Outstanding :> "bg-amber-100 text-amber-800 border-amber-200"
        }
    }

    export fn invoiceStatusLabel(status: InvoiceStatus) -> string {
        return match status {
            .Paid        :> "Paid"
            .Overdue     :> "Overdue"
            .Outstanding :> "Outstanding"
        }
    }

    export fn formatIsoDate(at: string) -> string {
        if (at is not || at == "") return "—"
        return at.substring(0, 10)
    }

    export const InvoiceCard = <tr class="border-b border-slate-200 hover:bg-slate-50" props={
        invoice: asIs,
        customerName: string,
        loadOriginCity?: string,
        loadDestinationCity?: string,
        todayIso: string,
        onMarkPaid: asIs,
    }>
        <td class="px-3 py-3 text-sm">
            <a class="text-blue-600 hover:underline font-medium" href="/dispatch/loads/${invoice.load_id}">
                #${invoice.load_id}
            </a>
            <div class="text-xs text-slate-500">
                ${loadOriginCity is not ? "" : loadOriginCity}
                <span if=(loadOriginCity is some && loadDestinationCity is some) class="text-slate-400 mx-1">→</span>
                ${loadDestinationCity is not ? "" : loadDestinationCity}
            </div>
        </td>

        <td class="px-3 py-3 text-sm text-slate-700">${customerName}</td>

        <td class="px-3 py-3 text-sm font-semibold text-slate-900 text-right">
            ${formatRate(invoice.amount_dollars)}
        </td>

        <td class="px-3 py-3 text-sm text-slate-700">${formatIsoDate(invoice.sent_at)}</td>
        <td class="px-3 py-3 text-sm text-slate-700">${formatIsoDate(invoice.due_at)}</td>

        <td class="px-3 py-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border ${invoiceStatusClasses(invoiceStatus(invoice, todayIso))}">
                ${invoiceStatusLabel(invoiceStatus(invoice, todayIso))}
            </span>
            <div if=(invoice.payment_reference is some && invoice.payment_reference != "") class="text-xs text-slate-500 mt-1">
                ${invoice.payment_reference}
            </div>
        </td>

        <td class="px-3 py-3 text-right">
            <button if=(invoice.paid_at is not || invoice.paid_at == "")
                onclick=onMarkPaid(invoice.id)
                class="text-xs px-3 py-1 bg-emerald-600 hover:bg-emerald-700 text-white rounded-md font-medium"
            >
                Mark paid
            </button>
            <span if=(invoice.paid_at is some && invoice.paid_at != "") class="text-xs text-slate-400">
                ${formatIsoDate(invoice.paid_at)}
            </>
        </td>
    </>
}
